{
  "name": "profilepro",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Portfolio professionnel de Samuel Dulex - Spécialiste en création de contenu vidéo et captation d'événements",
  "author": {
    "name": "Samuel Dulex",
    "url": "https://kuasar.xyz"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kuasar-mknd/profilePro.git"
  },
  "homepage": "https://portfolio.kuasar.xyz",
  "keywords": [
    "portfolio",
    "astro",
    "video",
    "photography",
    "content-creation",
    "samuel-dulex"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "5.0.1",
      "brace-expansion": "2.1.2",
      "serialize-javascript": "^7.0.3",
      "lodash": "^4.18.1",
      "tmp": "^0.2.6",
      "flatted": "^3.4.0",
      "undici": "^7.28.0",
      "minimatch": "^5.1.9",
      "yauzl": "^3.2.1",
      "fast-xml-parser": ">=5.10.1",
      "yaml": ">=2.8.3",
      "basic-ftp": ">=5.3.1",
      "uuid": ">=14.0.0",
      "qs": ">=6.15.2",
      "tar": ">=7.5.16",
      "body-parser": ">=1.20.6 <2.0.0",
      "sharp": ">=0.35.0",
      "astro-compress>svgo": ">=4.0.2",
      "@iconify/tools>svgo": ">=3.3.4",
      "vite>esbuild": ">=0.28.1",
      "astro>esbuild": ">=0.28.1"
    }
  },
  "scripts": {
    "audit": "node scripts/audit-bulk.mjs --level=high",
    "images": "node scripts/optimize-images.js",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && node scripts/generate-csp.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write \"src/**/*.{astro,js,jsx,ts,tsx,md,mdx}\"",
    "format:check": "prettier --check \"src/**/*.{astro,js,jsx,ts,tsx,md,mdx}\"",
    "lint": "pnpm run lint:eslint && pnpm run lint:stylelint",
    "lint:eslint": "eslint . --ext .js,.jsx,.ts,.tsx,.astro",
    "lint:eslint:fix": "eslint . --ext .js,.jsx,.ts,.tsx,.astro --fix",
    "lint:stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "lint:stylelint:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "lighthouse": "lhci autorun",
    "analyze": "ANALYZE=true pnpm run build && open dist/stats.html",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "typecheck": "astro check",
    "test:e2e": "playwright test",
    "prepare": "husky || true",
    "lint-staged": "lint-staged",
    "test": "bun test src/ tests/"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@iconify-json/mdi": "^1.2.3",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.3",
    "astro-compress": "^2.4.1",
    "astro-embed": "^0.13.1",
    "astro-icon": "^1.1.5",
    "cheerio": "^1.2.0",
    "dateformat": "^5.0.3",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "iconify-icon": "^3.0.2",
    "js-yaml": "^5.2.2",
    "lint-staged": "^17.2.0",
    "plyr": "^3.8.4",
    "rehype-external-links": "^3.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sanitize-html": "^2.17.6",
    "satori": "^0.28.2",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.11.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/dateformat": "^5.0.3",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "bun-types": "^1.3.14",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "happy-dom": "^20.11.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "semver": "^7.8.5",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.1.5",
    "wrangler": "^4.114.0"
  }
}
