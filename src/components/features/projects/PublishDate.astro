---
import dateFormat from "dateformat";
const { date } = Astro.props;

// ⚡ Bolt: Cache Intl.DateTimeFormat instance to avoid expensive instantiation
// Creating new Intl.DateTimeFormat instances is computationally expensive and
// slows down SSG builds significantly when used inside repeated components like Post cards.
const formatter =
  globalThis.__publishDateFormatter ||
  new Intl.DateTimeFormat("fr-FR", { dateStyle: "long" });
if (!globalThis.__publishDateFormatter) {
  globalThis.__publishDateFormatter = formatter;
}

// 🎨 Palette: Generate accessible label in French
const fullDate = formatter.format(date);
const label = `Publié le ${fullDate}`;
---

<time
  datetime={date.toISOString()}
  class="font-pacamara-space tracking-widest transition-all duration-300 text-[14px] text-inherit"
  aria-label={label}
>
  {dateFormat(date, "dd-mm-yyyy")}
</time>
