---
// Filtres par pilier éditorial (Création de contenu / Développement web /
// Communication), remplace l'ancien nuage de tags libres.
import { PILLARS } from "../../../utils/pillars";
import { sanitizeUrl } from "../../../utils/security";

interface Props {
  activePillar?: string;
  counts: Record<string, number>;
  totalCount: number;
}

const { activePillar, counts, totalCount } = Astro.props;

// Helper for pluralization
const getProjetsLabel = (count: number) => (count > 1 ? "projets" : "projet");
---

<nav
  id="project-filter-nav"
  aria-label="Filtres de projets"
  class="flex flex-wrap justify-center gap-4 my-8"
  style="contain: layout;"
>
  <a
    href="/project/"
    class={`project-filter-link px-4 py-2 rounded-full transition-all duration-300 border border-pacamara-secondary/30 backdrop-blur-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 hover:scale-105 active:scale-95 active:duration-75 hover:shadow-md
          ${!activePillar ? "bg-pacamara-accent text-white shadow-lg" : "bg-white/10 hover:bg-pacamara-accent/20 focus-visible:bg-pacamara-accent/20 text-pacamara-primary dark:text-white"}`}
    aria-current={!activePillar ? "page" : undefined}
    aria-label={!activePillar
      ? `Tous (${totalCount} ${getProjetsLabel(totalCount)}, filtre actif)`
      : `Tous (${totalCount} ${getProjetsLabel(totalCount)})`}
  >
    <span aria-hidden="true">
      Tous <span class="ml-1 text-xs opacity-70">({totalCount})</span>
    </span>
  </a>
  {
    PILLARS.map((pillar) => {
      const count = counts[pillar.slug] || 0;
      const isActive = activePillar === pillar.slug;
      return (
        <a
          href={sanitizeUrl(`/project/categorie/${pillar.slug}/`)}
          class={`project-filter-link px-4 py-2 rounded-full transition-all duration-300 border border-pacamara-secondary/30 backdrop-blur-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 hover:scale-105 active:scale-95 active:duration-75 hover:shadow-md
            ${isActive ? "bg-pacamara-accent text-white shadow-lg" : "bg-white/10 hover:bg-pacamara-accent/20 focus-visible:bg-pacamara-accent/20 text-pacamara-primary dark:text-white"}`}
          aria-current={isActive ? "page" : undefined}
          aria-label={
            isActive
              ? `${pillar.label} (${count} ${getProjetsLabel(count)}, filtre actif)`
              : `${pillar.label} (${count} ${getProjetsLabel(count)})`
          }
        >
          <span aria-hidden="true">
            {pillar.label}{" "}
            <span class="ml-1 text-xs opacity-70">({count})</span>
          </span>
        </a>
      );
    })
  }
</nav>
