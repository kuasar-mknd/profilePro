---
import { Icon } from "astro-icon/components";

interface Props {
  icon: string;
  url: string;
  label: string;
}

import { sanitizeUrl } from "../../utils/security";

const { icon, url, label } = Astro.props;

// 🛡️ Sentinel: Sanitize URL to prevent XSS (javascript: URI)
// Allow http, https, mailto, tel, sms, and relative paths (/)
const safeUrl = sanitizeUrl(url) || "#";

// Palette: Accessibility enhancement
// Append warning for external links (which open in new tab)
// Note: tel: and mailto: links might open in a new app/tab depending on browser behavior, so we keep the warning or adjust?
// For consistency, we keep the warning as they navigate "away" from the current context.
const suffix = " (ouvre un nouvel onglet)";
const baseLabel = label || "Lien social";
const a11yLabel = baseLabel.includes(suffix) ? baseLabel : baseLabel + suffix;
---

<a
  href={safeUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="group relative flex h-10 w-10 items-center justify-center rounded-full bg-pacamara-primary/5 transition-all duration-300 hover:scale-110 focus-visible:scale-110 hover:bg-pacamara-accent focus-visible:bg-pacamara-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 dark:bg-pacamara-white/10 dark:hover:bg-pacamara-accent"
  style="contain: layout style;"
  aria-label={a11yLabel}
>
  <Icon
    name={icon}
    class="h-5 w-5 text-pacamara-primary transition-colors duration-300 group-hover:text-white group-focus-visible:text-white dark:text-pacamara-white"
    aria-hidden="true"
  />

  <!-- 🎨 Palette: Custom Visual Tooltip -->
  <span
    class="absolute -top-10 left-1/2 -translate-x-1/2 px-2.5 py-1 bg-pacamara-dark text-white text-xs font-medium rounded-md opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-all duration-300 pointer-events-none whitespace-nowrap dark:bg-white dark:text-pacamara-dark shadow-md transform translate-y-2 group-hover:translate-y-0 group-focus-visible:translate-y-0 flex flex-col items-center"
    aria-hidden="true"
  >
    <span class="flex items-center gap-1">
      {baseLabel}
      <Icon
        name="mdi:open-in-new"
        class="w-3 h-3 opacity-70"
        aria-hidden="true"
      />
    </span>
    <span
      class="absolute top-full left-1/2 -translate-x-1/2 w-0 h-0 border-x-4 border-x-transparent border-t-[5px] border-t-pacamara-dark dark:border-t-white"
    ></span>
  </span>
</a>
