<button
  id="menu_toggle"
  class="block md:hidden cursor-pointer text-white group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 rounded-lg p-1"
  type="button"
  aria-controls="navigation_wrapper"
  aria-expanded="false"
  aria-label="Ouvrir le menu"
>
  <div
    class="relative w-8 h-6 flex flex-col justify-between items-center group-hover:scale-105 group-focus-visible:scale-105 transition-transform duration-300"
  >
    <span
      aria-hidden="true"
      class="w-full h-0.5 bg-pacamara-dark dark:bg-pacamara-accent rounded-full transition-all duration-300 origin-left group-aria-expanded:rotate-45 group-aria-expanded:translate-x-1"
    ></span>
    <span
      aria-hidden="true"
      class="w-full h-0.5 bg-pacamara-dark dark:bg-pacamara-accent rounded-full transition-all duration-300 group-aria-expanded:opacity-0"
    ></span>
    <span
      aria-hidden="true"
      class="w-full h-0.5 bg-pacamara-dark dark:bg-pacamara-accent rounded-full transition-all duration-300 origin-left group-aria-expanded:-rotate-45 group-aria-expanded:translate-x-1"
    ></span>
  </div>
  <span class="sr-only" aria-live="polite" id="menu-live-region"></span>

  <!-- 🎨 Palette: Custom Visual Tooltip -->
  <span
    class="absolute top-full right-0 mt-3 px-2.5 py-1.5 bg-pacamara-dark text-white text-xs font-medium rounded-md opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap dark:bg-white dark:text-pacamara-dark shadow-md z-[60]"
    aria-hidden="true"
  >
    <span id="menu_tooltip_text">Menu</span><kbd
      id="menu_tooltip_shortcut"
      class="font-sans ml-1 opacity-70 hidden"
      aria-hidden="true">(Esc)</kbd
    >
    <span
      class="absolute bottom-full right-3 w-0 h-0 border-x-4 border-x-transparent border-b-[5px] border-b-pacamara-dark dark:border-b-white"
    ></span>
  </span>
</button>

<script>
  /**
   * ⚡ Bolt: HamburgerButton Performance Optimization
   * Added initialization guard to prevent duplicate observers and handlers
   */
  let cleanupMenu: (() => void) | null = null;

  function initMenu() {
    // ⚡ Bolt: Cleanup previous listeners to prevent memory leaks on navigation
    if (cleanupMenu) {
      cleanupMenu();
      cleanupMenu = null;
    }

    const button = document.querySelector("#menu_toggle");
    const nav = document.querySelector("#navigation_wrapper");
    const tooltipText = document.querySelector("#menu_tooltip_text");
    const tooltipShortcut = document.querySelector("#menu_tooltip_shortcut");

    // ⚡ Early return guards
    if (!button || !nav) return;
    if ((button as HTMLElement).dataset.initialized === "true") return;
    (button as HTMLElement).dataset.initialized = "true";

    // 🎨 Palette: Encapsulated close logic for reusability
    const closeMenu = () => {
      document.documentElement.classList.remove("overflow-hidden");
      button.setAttribute("aria-expanded", "false");
      button.setAttribute("aria-label", "Ouvrir le menu");
      button.removeAttribute("aria-keyshortcuts");

      if (tooltipText) tooltipText.textContent = "Menu";
      if (tooltipShortcut) {
        tooltipShortcut.classList.remove("sm:inline");
      }
      nav.classList.add("translate-x-full");
      nav.classList.remove("translate-x-0");

      // 🎨 Palette: Remove inert and aria-hidden from background content
      const mainContent = document.getElementById("main-content");
      const mainFooter = document.getElementById("main-footer");
      if (mainContent) {
        mainContent.removeAttribute("inert");
        mainContent.removeAttribute("aria-hidden");
      }
      if (mainFooter) {
        mainFooter.removeAttribute("inert");
        mainFooter.removeAttribute("aria-hidden");
      }

      // ⚡ Bolt: Wait for transition to finish before hiding (approx 300ms)
      setTimeout(() => {
        if (button.getAttribute("aria-expanded") === "false") {
          nav.classList.add("invisible");
          // ⚡ Bolt: Remove GPU layer promotion to free memory
          (nav as HTMLElement).style.willChange = "auto";
        }
      }, 300);
    };

    const openMenu = () => {
      // ⚡ Bolt: Make visible immediately so transition can be seen
      nav.classList.remove("invisible");

      // ⚡ Bolt: Promote layer for smooth animation
      (nav as HTMLElement).style.willChange = "transform";

      // Force reflow to ensure transition triggers
      void (nav as HTMLElement).offsetWidth;

      document.documentElement.classList.add("overflow-hidden");
      button.setAttribute("aria-expanded", "true");
      button.setAttribute("aria-label", "Fermer le menu");
      button.setAttribute("aria-keyshortcuts", "Escape");

      if (tooltipText) tooltipText.textContent = "Fermer";
      if (tooltipShortcut) {
        tooltipShortcut.classList.add("sm:inline");
      }
      nav.classList.remove("translate-x-full");
      nav.classList.add("translate-x-0");

      // 🎨 Palette: Apply inert and aria-hidden to background content
      const mainContent = document.getElementById("main-content");
      const mainFooter = document.getElementById("main-footer");
      if (mainContent) {
        mainContent.setAttribute("inert", "");
        mainContent.setAttribute("aria-hidden", "true");
      }
      if (mainFooter) {
        mainFooter.setAttribute("inert", "");
        mainFooter.setAttribute("aria-hidden", "true");
      }
    };

    // ⚡ Bolt: Cache matchMedia to avoid re-parsing inside event listener
    const prefersReducedMotionQuery = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    );

    button.addEventListener("click", function () {
      const isExpanded = button.getAttribute("aria-expanded") === "true";

      // 🎨 Palette: Announce menu state change to screen readers
      const liveRegion = document.getElementById("menu-live-region");

      if (isExpanded) {
        closeMenu();
        if (liveRegion) liveRegion.textContent = "Menu fermé";
      } else {
        openMenu();
        if (liveRegion) liveRegion.textContent = "Menu ouvert";
      }

      // 🎨 Palette: Provide subtle haptic feedback for mobile users
      if (navigator.vibrate && !prefersReducedMotionQuery.matches) {
        navigator.vibrate(50);
      }
    });

    // ⚡ Bolt: Use event delegation instead of attaching N listeners via querySelectorAll
    nav.addEventListener("click", (e: Event) => {
      const target = e.target as HTMLElement;
      if (target.closest("a")) {
        closeMenu();
      }
    });

    // 🎨 Palette: Close menu on Escape key for accessibility
    const handleEscape = (e: KeyboardEvent) => {
      if (
        e.key === "Escape" &&
        button.getAttribute("aria-expanded") === "true"
      ) {
        closeMenu();
        (button as HTMLElement).focus();
      }
    };

    document.addEventListener("keydown", handleEscape);

    const menuObserver = new MutationObserver((mutations) => {
      // ⚡ Bolt: Optimized forEach loop into a standard for loop to avoid array callback allocation.
      for (let i = 0; i < mutations.length; i++) {
        const mutation = mutations[i];
        if (mutation.attributeName === "class") {
          const isMenuOpen =
            document.documentElement.classList.contains("overflow-hidden");

          if (button.getAttribute("aria-expanded") !== String(isMenuOpen)) {
            button.setAttribute("aria-expanded", String(isMenuOpen));
          }

          if (isMenuOpen) {
            nav.classList.remove("invisible");
            nav.classList.remove("translate-x-full");
            nav.classList.add("translate-x-0");
          } else {
            nav.classList.add("translate-x-full");
            nav.classList.remove("translate-x-0");
          }
        }
      }
    });

    menuObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    // ⚡ Register cleanup
    cleanupMenu = () => {
      document.removeEventListener("keydown", handleEscape);
      menuObserver.disconnect();
    };
  }

  if (window.__menuInitHandler) {
    document.removeEventListener("astro:page-load", window.__menuInitHandler);
  }
  window.__menuInitHandler = initMenu;
  document.addEventListener("astro:page-load", initMenu);
</script>
