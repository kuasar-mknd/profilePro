---
const { pathname } = Astro.url;
const normalizePath = (path: string) => path.replace(/\/$/, "") || "/";
const currentPath = normalizePath(pathname);
---

<nav aria-label="Menu principal">
  <ul
    class="list-none text-2xl md:text-[14px] font-normal flex flex-initial flex-col md:flex-row gap-8 md:gap-5 whitespace-nowrap"
    style="contain: layout;"
  >
    <li class="nav-item">
      <a
        href="/"
        class={`transition-all duration-300 link-animated focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 rounded-lg px-2 -mx-2 ${
          currentPath === "/"
            ? "opacity-100 text-pacamara-accent dark:text-pacamara-accent font-medium link-active"
            : "opacity-60 text-pacamara-primary hover:opacity-100 hover:text-pacamara-accent dark:text-white dark:hover:text-pacamara-accent focus-visible:opacity-100 focus-visible:text-pacamara-accent dark:focus-visible:text-pacamara-accent"
        }`}
        aria-current={currentPath === "/" ? "page" : undefined}
        aria-label="Accueil (Alt+1)"
        aria-keyshortcuts="Alt+1"
      >
        Accueil <kbd
          class="font-sans ml-1 opacity-70 hidden md:inline-block text-[10px] bg-pacamara-primary/5 dark:bg-white/10 px-1.5 py-0.5 rounded"
          aria-hidden="true">(1)</kbd
        ></a
      >
    </li>
    <li class="nav-item">
      <a
        href="/project/"
        class={`transition-all duration-300 link-animated focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 rounded-lg px-2 -mx-2 ${
          currentPath.startsWith("/project")
            ? "opacity-100 text-pacamara-accent dark:text-pacamara-accent font-medium link-active"
            : "opacity-60 text-pacamara-primary hover:opacity-100 hover:text-pacamara-accent dark:text-white dark:hover:text-pacamara-accent focus-visible:opacity-100 focus-visible:text-pacamara-accent dark:focus-visible:text-pacamara-accent"
        }`}
        aria-current={currentPath.startsWith("/project") ? "page" : undefined}
        aria-label="Projets (Alt+2)"
        aria-keyshortcuts="Alt+2"
      >
        Projets <kbd
          class="font-sans ml-1 opacity-70 hidden md:inline-block text-[10px] bg-pacamara-primary/5 dark:bg-white/10 px-1.5 py-0.5 rounded"
          aria-hidden="true">(2)</kbd
        ></a
      >
    </li>
    <li class="nav-item">
      <a
        href="/about/"
        class={`transition-all duration-300 link-animated focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 rounded-lg px-2 -mx-2 ${
          currentPath === "/about"
            ? "opacity-100 text-pacamara-accent dark:text-pacamara-accent font-medium link-active"
            : "opacity-60 text-pacamara-primary hover:opacity-100 hover:text-pacamara-accent dark:text-white dark:hover:text-pacamara-accent focus-visible:opacity-100 focus-visible:text-pacamara-accent dark:focus-visible:text-pacamara-accent"
        }`}
        aria-current={currentPath === "/about" ? "page" : undefined}
        aria-label="À propos (Alt+3)"
        aria-keyshortcuts="Alt+3"
      >
        À propos <kbd
          class="font-sans ml-1 opacity-70 hidden md:inline-block text-[10px] bg-pacamara-primary/5 dark:bg-white/10 px-1.5 py-0.5 rounded"
          aria-hidden="true">(3)</kbd
        ></a
      >
    </li>
  </ul>
</nav>

<script>
  // ⚡ Bolt: Cache MediaQueryList globally to prevent evaluating the media query string on every click or component init
  const prefersReducedMotionQuery = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  );

  /**
   * 🎨 Palette: Tactile feedback for primary navigation
   * Provides a subtle physical confirmation when interacting with the main menu.
   */
  function initNavHaptics() {
    const nav = document.querySelector('nav[aria-label="Menu principal"]');
    if (!nav || (nav as HTMLElement).dataset.hapticsInitialized === "true")
      return;

    (nav as HTMLElement).dataset.hapticsInitialized = "true";

    nav.addEventListener("click", (e: Event) => {
      const target = e.target as HTMLElement;
      if (target.closest(".nav-item a")) {
        // 🎨 Palette: Respect user preferences for reduced motion/haptics
        if (navigator.vibrate && !prefersReducedMotionQuery.matches) {
          navigator.vibrate(30);
        }
      }
    });
  }

  // Support View Transitions
  if (window.__navHapticsInitHandler) {
    document.removeEventListener(
      "astro:page-load",
      window.__navHapticsInitHandler,
    );
  }
  window.__navHapticsInitHandler = initNavHaptics;
  document.addEventListener("astro:page-load", initNavHaptics);
  initNavHaptics();

  /**
   * 🎨 Palette: Global keyboard shortcuts for main navigation
   */
  import { navigate } from "astro:transitions/client";

  const handleNavKeydown = (e: KeyboardEvent) => {
    // Ignore if user is typing in an input
    const target = e.target as HTMLElement;
    if (
      target.tagName === "INPUT" ||
      target.tagName === "TEXTAREA" ||
      target.isContentEditable
    ) {
      return;
    }

    if (e.altKey && !e.ctrlKey && !e.metaKey && !e.shiftKey) {
      if (e.key === "1") {
        e.preventDefault();
        navigate("/");
      } else if (e.key === "2") {
        e.preventDefault();
        navigate("/project/");
      } else if (e.key === "3") {
        e.preventDefault();
        navigate("/about/");
      }
    }
  };

  if (window.__navKeydownHandler) {
    document.removeEventListener("keydown", window.__navKeydownHandler);
  }
  window.__navKeydownHandler = handleNavKeydown;
  document.addEventListener("keydown", window.__navKeydownHandler);
</script>
