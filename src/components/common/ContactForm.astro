---
import { Icon } from "astro-icon/components";
---

{
  /* ⚡ Bolt: Performance Optimization - content-visibility skips rendering when off-screen */
}
<form
  action={import.meta.env.DEV
    ? "https://api.web3forms.com/submit"
    : "/api/submit"}
  method="POST"
  class="contact-form-section w-full max-w-lg mx-auto bg-white/80 dark:bg-pacamara-dark/60 backdrop-blur-xl p-8 md:p-10 rounded-3xl border border-pacamara-secondary/10 dark:border-white/10 shadow-2xl relative overflow-hidden [content-visibility:auto] [contain-intrinsic-size:auto_600px] contain-layout-paint"
  id="contact-form"
>
  <!-- Form Success Message -->
  <div
    id="form-success-message"
    class="hidden absolute inset-0 z-20 items-center justify-center bg-white/80 dark:bg-pacamara-dark/60 backdrop-blur-xl p-8 text-center focus:outline-none"
    role="status"
    aria-live="polite"
    tabindex="-1"
  >
    <div class="space-y-4 animate-fade-in-up">
      <Icon
        name="mdi:check-circle"
        class="w-16 h-16 text-green-500 mx-auto"
        aria-hidden="true"
      />
      <h3 class="text-2xl font-bold text-pacamara-primary dark:text-white">
        Message envoyé !
      </h3>
      <p class="text-pacamara-primary/80 dark:text-white/80">
        Merci de m'avoir contacté. Je vous répondrai dans les plus brefs délais.
      </p>
      <button
        type="button"
        data-haptic="50"
        class="reset-form-btn group cursor-pointer mt-6 px-6 py-3 bg-pacamara-secondary/10 dark:bg-white/10 hover:bg-pacamara-secondary/20 dark:hover:bg-white/20 text-pacamara-primary dark:text-white font-medium rounded-xl transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 flex items-center justify-center gap-2 mx-auto"
      >
        <Icon
          name="mdi:refresh"
          class="w-5 h-5 transition-transform duration-300 group-hover:rotate-180 group-focus-visible:rotate-180"
          aria-hidden="true"
        />
        <span>Envoyer un autre message</span>
      </button>
    </div>
  </div>

  <!-- Decorative gradient corner -->
  <div
    class="absolute -top-20 -right-20 w-40 h-40 bg-linear-to-br from-pacamara-secondary/20 to-pacamara-accent/20 rounded-full blur-2xl pointer-events-none"
  >
  </div>

  <!-- 🛡️ Sentinel: Obfuscated Access Key to prevent scraping -->

  <!-- Optional: Subject -->
  <input type="hidden" name="subject" value="Nouveau message du Portfolio" />

  <!-- 🛡️ Sentinel: Hardened honeypot to prevent autofill and screen reader access -->
  <input
    type="checkbox"
    name="botcheck"
    class="hidden"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />

  <!-- 🛡️ Sentinel: Timestamp trap to prevent spam -->
  <input
    type="hidden"
    name="form-load-timestamp"
    id="form-load-timestamp"
    value=""
  />

  <div class="space-y-6 relative z-10">
    <!-- Name Field -->
    <div class="form-group group">
      <label
        for="name"
        class="block mb-2 text-sm font-medium text-pacamara-primary dark:text-white group-focus-within:text-pacamara-accent transition-colors duration-300"
      >
        Nom complet <span class="sr-only">(obligatoire)</span><span
          aria-hidden="true"
          class="text-pacamara-accent">*</span
        >
      </label>
      <div class="relative">
        <input
          type="text"
          name="name"
          id="name"
          autocomplete="name"
          required
          aria-describedby="name-hint"
          aria-required="true"
          maxlength="100"
          minlength="2"
          inputmode="text"
          class="form-input w-full pl-5 pr-12 py-4 rounded-xl bg-white dark:bg-pacamara-dark border-2 border-pacamara-secondary/10 focus:border-pacamara-accent focus:ring-4 focus:ring-pacamara-accent/10 outline-none transition-all duration-300 dark:text-white text-base placeholder:text-pacamara-primary/40 dark:placeholder:text-white/30"
          placeholder="Votre nom"
        />
        <div
          class="input-glow absolute inset-0 rounded-xl opacity-0 pointer-events-none transition-opacity duration-300"
          aria-hidden="true"
        >
        </div>
        <!-- 🎨 Palette: Validation Icon -->
        <div
          class="validation-icon absolute right-4 top-1/2 -translate-y-1/2 text-green-500 opacity-0 scale-50 transition-all duration-300 pointer-events-none data-[visible=true]:opacity-100 data-[visible=true]:scale-100"
          aria-hidden="true"
        >
          <Icon name="mdi:check-circle" class="w-6 h-6" aria-hidden="true" />
        </div>
      </div>
      <p id="name-hint" class="sr-only">Au moins 2 caractères.</p>
    </div>

    <!-- Email Field -->
    <div class="form-group group">
      <label
        for="email"
        class="block mb-2 text-sm font-medium text-pacamara-primary dark:text-white group-focus-within:text-pacamara-accent transition-colors duration-300"
      >
        Email <span class="sr-only">(obligatoire)</span><span
          aria-hidden="true"
          class="text-pacamara-accent">*</span
        >
      </label>
      <div class="relative">
        <input
          type="email"
          name="email"
          id="email"
          autocomplete="email"
          required
          aria-describedby="email-hint"
          aria-required="true"
          maxlength="254"
          inputmode="email"
          spellcheck="false"
          class="form-input w-full pl-5 pr-12 py-4 rounded-xl bg-white dark:bg-pacamara-dark border-2 border-pacamara-secondary/10 focus:border-pacamara-accent focus:ring-4 focus:ring-pacamara-accent/10 outline-none transition-all duration-300 dark:text-white text-base placeholder:text-pacamara-primary/40 dark:placeholder:text-white/30"
          placeholder="votre@email.com"
        />
        <div
          class="input-glow absolute inset-0 rounded-xl opacity-0 pointer-events-none transition-opacity duration-300"
          aria-hidden="true"
        >
        </div>
        <!-- 🎨 Palette: Validation Icon -->
        <div
          class="validation-icon absolute right-4 top-1/2 -translate-y-1/2 text-green-500 opacity-0 scale-50 transition-all duration-300 pointer-events-none data-[visible=true]:opacity-100 data-[visible=true]:scale-100"
          aria-hidden="true"
        >
          <Icon name="mdi:check-circle" class="w-6 h-6" aria-hidden="true" />
        </div>
      </div>
      <p id="email-hint" class="sr-only">Format d'adresse email valide.</p>
    </div>

    <!-- Message Field -->
    <div class="form-group group">
      <label
        for="message"
        class="block mb-2 text-sm font-medium text-pacamara-primary dark:text-white group-focus-within:text-pacamara-accent transition-colors duration-300"
      >
        Message <span class="sr-only">(obligatoire)</span><span
          aria-hidden="true"
          class="text-pacamara-accent">*</span
        >
      </label>
      <div class="relative">
        <textarea
          name="message"
          id="message"
          rows="4"
          required
          aria-describedby="message-hint"
          aria-required="true"
          maxlength="5000"
          minlength="10"
          autocomplete="off"
          class="form-input w-full pl-5 pr-12 py-4 rounded-xl bg-white dark:bg-pacamara-dark border-2 border-pacamara-secondary/10 focus:border-pacamara-accent focus:ring-4 focus:ring-pacamara-accent/10 outline-none transition-colors transition-shadow duration-300 dark:text-white text-base placeholder:text-pacamara-primary/40 dark:placeholder:text-white/30 resize-none overflow-hidden"
          placeholder="Parlez-moi de votre projet..."></textarea>
        <div
          class="input-glow absolute inset-0 rounded-xl opacity-0 pointer-events-none"
          aria-hidden="true"
        >
        </div>
        <!-- 🎨 Palette: Validation Icon (Top Right for Textarea) -->
        <div
          class="validation-icon absolute right-4 top-4 text-green-500 opacity-0 scale-50 transition-all duration-300 pointer-events-none data-[visible=true]:opacity-100 data-[visible=true]:scale-100"
          aria-hidden="true"
        >
          <Icon name="mdi:check-circle" class="w-6 h-6" aria-hidden="true" />
        </div>
      </div>
      <p id="message-hint" class="sr-only">
        Au moins 10 caractères. Maximum 5000 caractères.
      </p>
      <!-- 🎨 Palette: Character counter -->
      <div class="flex justify-end mt-1 gap-2">
        <div
          id="message-counter"
          class="text-xs text-pacamara-primary/60 dark:text-white/60 font-medium transition-colors duration-300"
        >
          0 / 5000
        </div>
        <!-- Accessible announcer for thresholds -->
        <div id="message-counter-sr" class="sr-only" aria-live="polite"></div>
      </div>
    </div>

    <!-- Submit Button -->
    <button
      type="submit"
      class="submit-btn cursor-pointer w-full py-4 px-6 bg-pacamara-accent hover:bg-pacamara-secondary text-white font-bold rounded-xl transition-all duration-300 shadow-lg hover:shadow-glow-accent hover-lift flex items-center justify-center gap-3 text-lg relative overflow-hidden group focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 aria-disabled:opacity-70 aria-disabled:cursor-not-allowed aria-disabled:hover:bg-pacamara-accent aria-disabled:hover:shadow-lg aria-disabled:hover:-translate-y-0"
      aria-live="polite"
    >
      <span class="btn-text relative z-10">Envoyer le message</span>
      <Icon
        name="mdi:send"
        class="w-5 h-5 relative z-10 group-hover:translate-x-1 group-focus-visible:translate-x-1 transition-transform"
        aria-hidden="true"
      />
      <span
        class="btn-loading hidden absolute inset-0 items-center justify-center"
        aria-label="Envoi en cours..."
      >
        <svg
          class="animate-spin h-6 w-6 text-white"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <circle
            class="opacity-25"
            cx="12"
            cy="12"
            r="10"
            stroke="currentColor"
            stroke-width="4"></circle>
          <path
            class="opacity-75"
            fill="currentColor"
            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
          ></path>
        </svg>
      </span>
      <span
        class="btn-success hidden absolute inset-0 items-center justify-center gap-2"
        aria-label="Message envoyé avec succès"
      >
        <Icon name="mdi:check-circle" class="w-6 h-6" aria-hidden="true" />
        <span>Message envoyé !</span>
      </span>
      <!-- Ripple effect container -->
      <div class="btn-ripple absolute inset-0 pointer-events-none"></div>
    </button>

    <!-- Inline Error Message -->
    <div
      id="form-error-message"
      class="hidden mt-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl text-red-600 dark:text-red-400 text-sm text-center focus:outline-none focus:ring-2 focus:ring-red-500/80 focus:ring-offset-2 focus:ring-offset-white dark:focus:ring-offset-pacamara-dark"
      role="alert"
      aria-live="assertive"
      tabindex="-1"
    >
      <p id="error-text">Une erreur est survenue. Veuillez réessayer.</p>
      <button
        type="button"
        id="reset-error-btn"
        data-haptic="50"
        class="group mt-4 px-4 py-2 cursor-pointer bg-red-100 dark:bg-red-900/30 hover:bg-red-200 dark:hover:bg-red-900/50 text-red-800 dark:text-red-300 font-medium rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-500 inline-flex items-center gap-2"
        aria-label="Réessayer de soumettre le formulaire"
      >
        <Icon
          name="mdi:refresh"
          class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180 group-focus-visible:rotate-180"
          aria-hidden="true"
        />
        <span>Réessayer</span>
      </button>
    </div>
  </div>

  <p
    class="text-xs text-center mt-6 text-pacamara-primary/50 dark:text-white/50"
  >
    Les champs marqués d'un <span class="sr-only">astérisque</span><span
      class="text-pacamara-accent"
      aria-hidden="true">*</span
    > sont obligatoires.
  </p>
  <p
    class="text-xs text-center mt-2 text-pacamara-primary/50 dark:text-white/50"
  >
    Powered by Web3Forms
  </p>
</form>

<style>
  .input-glow {
    box-shadow: 0 0 20px rgba(190, 18, 60, 0.15);
  }

  .form-input:focus ~ .input-glow {
    opacity: 1;
  }

  .submit-btn.loading .btn-text,
  .submit-btn.loading svg:not(.animate-spin) {
    display: none;
  }
  .submit-btn.loading .btn-loading {
    display: flex;
  }

  .submit-btn.success {
    background-color: #10b981;
  }
  .submit-btn.success .btn-text,
  .submit-btn.success svg:not(.animate-spin):first-of-type {
    display: none;
  }
  .submit-btn.success .btn-success {
    display: flex;
  }

  @keyframes ripple {
    to {
      transform: scale(4);
      opacity: 0;
    }
  }

  .ripple-circle {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: scale(0);
    animation: ripple 0.6s linear;
    pointer-events: none;
  }

  .form-input:focus-visible {
    outline: 2px solid var(--color-pacamara-accent);
    outline-offset: 2px;
  }

  [aria-invalid="true"] {
    border-color: #ef4444;
    box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.2);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.4s ease-out forwards;
  }

  @keyframes highlightGlow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(190, 18, 60, 0);
    }
    50% {
      box-shadow: 0 0 30px 10px rgba(190, 18, 60, 0.3);
    }
  }

  .form-highlight {
    animation: highlightGlow 1.5s ease-in-out;
  }
</style>

<script>
  import { sanitizeInput, isValidEmail } from "../../utils/security";

  // ⚡ Bolt: Cache matchMedia globally at module scope to avoid re-parsing on component load/instantiation
  const prefersReducedMotionQuery = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  );

  class ContactFormController {
    private form: HTMLFormElement;
    private timestampInput: HTMLInputElement;
    private submitButton: HTMLButtonElement;
    private resetBtn: HTMLButtonElement;
    private errorResetBtn: HTMLButtonElement;
    private errorMessage: HTMLElement;
    private errorText: HTMLParagraphElement;
    private nameInput: HTMLInputElement;
    private emailInput: HTMLInputElement;
    private messageInput: HTMLTextAreaElement;
    private messageCounter: HTMLElement;
    private messageCounterSr: HTMLElement;

    private maxMessageLength: number = 5000;
    private resizeRaf: number | null = null;

    constructor(form: HTMLFormElement) {
      this.form = form;
      if (this.form.dataset.initialized === "true") return;
      this.form.dataset.initialized = "true";
      this.form.setAttribute("novalidate", "true");

      this.timestampInput = document.getElementById(
        "form-load-timestamp",
      ) as HTMLInputElement;
      if (this.timestampInput) {
        this.timestampInput.value = Date.now().toString();
      }

      this.submitButton = this.form.querySelector(
        ".submit-btn",
      ) as HTMLButtonElement;
      this.resetBtn = this.form.querySelector(
        ".reset-form-btn",
      ) as HTMLButtonElement;
      this.errorResetBtn = document.getElementById(
        "reset-error-btn",
      ) as HTMLButtonElement;
      this.errorMessage = document.getElementById(
        "form-error-message",
      ) as HTMLElement;
      this.errorText = document.getElementById(
        "error-text",
      ) as HTMLParagraphElement;
      this.nameInput = this.form.querySelector(
        'input[name="name"]',
      ) as HTMLInputElement;
      this.emailInput = this.form.querySelector(
        'input[name="email"]',
      ) as HTMLInputElement;
      this.messageInput = this.form.querySelector(
        'textarea[name="message"]',
      ) as HTMLTextAreaElement;
      this.messageCounter = document.getElementById(
        "message-counter",
      ) as HTMLElement;
      this.messageCounterSr = document.getElementById(
        "message-counter-sr",
      ) as HTMLElement;

      if (this.messageInput && this.messageCounter) {
        const maxLength = this.messageInput.getAttribute("maxlength") || "5000";
        this.maxMessageLength = parseInt(maxLength, 10);
      }

      this.bindEvents();

      if (this.messageInput && this.messageCounter) {
        this.updateCounter();
        this.autoResizeTextarea();
      }
    }

    private autoResizeTextarea = () => {
      if (!this.messageInput) return;
      if (this.resizeRaf) cancelAnimationFrame(this.resizeRaf);
      this.resizeRaf = requestAnimationFrame(() => {
        this.messageInput.style.height = "auto";
        this.messageInput.style.height = `${this.messageInput.scrollHeight}px`;
        this.resizeRaf = null;
      });
    };

    private updateCounter = () => {
      if (!this.messageInput || !this.messageCounter) return;
      const currentLength = this.messageInput.value.length;
      const remaining = this.maxMessageLength - currentLength;
      this.messageCounter.textContent = `${currentLength} / ${this.maxMessageLength}`;

      if (currentLength >= this.maxMessageLength) {
        this.messageCounter.classList.add("text-red-500", "dark:text-red-400");
        this.messageCounter.classList.remove(
          "text-orange-600",
          "dark:text-orange-400",
          "text-pacamara-primary/60",
          "dark:text-white/60",
        );
        if (this.messageCounterSr)
          this.messageCounterSr.textContent =
            "Limite de caractères atteinte. 0 caractères restants.";
      } else if (currentLength >= this.maxMessageLength * 0.9) {
        this.messageCounter.classList.add(
          "text-orange-600",
          "dark:text-orange-400",
        );
        this.messageCounter.classList.remove(
          "text-red-500",
          "dark:text-red-400",
          "text-pacamara-primary/60",
          "dark:text-white/60",
        );
        if (this.messageCounterSr && remaining % 20 === 0) {
          this.messageCounterSr.textContent = `Attention, plus que ${remaining} caractères.`;
        }
      } else {
        this.messageCounter.classList.add(
          "text-pacamara-primary/60",
          "dark:text-white/60",
        );
        this.messageCounter.classList.remove(
          "text-red-500",
          "dark:text-red-400",
          "text-orange-600",
          "dark:text-orange-400",
        );
        if (this.messageCounterSr) this.messageCounterSr.textContent = "";
      }
    };

    private hideErrorIfFormIsValid = () => {
      if (
        this.nameInput?.value.trim().length >= 2 &&
        isValidEmail(this.emailInput?.value || "") &&
        this.messageInput?.value.trim().length >= 10
      ) {
        this.errorMessage?.classList.add("hidden");
      }
    };

    private updateValidationIcon = (
      input: HTMLInputElement | HTMLTextAreaElement,
      isValid: boolean,
    ) => {
      const iconWrapper = input.parentNode?.querySelector(
        ".validation-icon",
      ) as HTMLElement;
      if (iconWrapper) {
        iconWrapper.dataset.visible = isValid ? "true" : "false";
      }
    };

    private showError = (message: string, fieldToFocus?: HTMLElement) => {
      // 🎨 Palette: Distinct tactile pattern for errors
      if (navigator.vibrate && !prefersReducedMotionQuery.matches)
        navigator.vibrate([50, 50, 50]);

      if (this.errorMessage && this.errorText) {
        this.errorText.textContent = message;
        this.errorMessage.classList.remove("hidden");
        if (fieldToFocus) {
          fieldToFocus.focus();
        } else {
          this.errorMessage.focus();
        }
      }
    };

    private bindEvents() {
      if (this.messageInput) {
        this.messageInput.addEventListener("input", () => {
          this.updateCounter();
          this.autoResizeTextarea();
          const isValid = this.messageInput.value.trim().length >= 10;
          this.updateValidationIcon(this.messageInput, isValid);

          if (this.messageInput.hasAttribute("aria-invalid") && isValid) {
            this.messageInput.removeAttribute("aria-invalid");
            const currentDesc =
              this.messageInput.getAttribute("aria-describedby") || "";
            this.messageInput.setAttribute(
              "aria-describedby",
              currentDesc.replace("form-error-message", "").trim(),
            );
            this.hideErrorIfFormIsValid();
          }
        });
      }

      this.resetBtn?.addEventListener("click", () => {
        // 🎨 Palette: Subtle tactile feedback
        if (navigator.vibrate && !prefersReducedMotionQuery.matches)
          navigator.vibrate(30);

        const successMessage = document.getElementById("form-success-message");
        successMessage?.classList.add("hidden");
        successMessage?.classList.remove("flex");
        this.form.reset();
        if (this.messageCounter && this.messageInput) {
          this.messageInput.style.height = "auto";
          this.messageCounter.textContent = `0 / ${this.messageInput.getAttribute("maxlength") || "5000"}`;
          this.messageCounter.classList.remove(
            "text-red-500",
            "dark:text-red-400",
            "text-orange-600",
            "dark:text-orange-400",
          );
          this.messageCounter.classList.add(
            "text-pacamara-primary/60",
            "dark:text-white/60",
          );
        }
        const icons = this.form.querySelectorAll(".validation-icon");
        for (let i = 0; i < icons.length; i++) {
          (icons[i] as HTMLElement).dataset.visible = "false";
        }

        if (this.submitButton) {
          this.submitButton.removeAttribute("aria-disabled");
          this.submitButton.removeAttribute("aria-busy");
          this.submitButton.classList.remove("loading");
        }

        if (this.nameInput) {
          const currentDesc =
            this.nameInput.getAttribute("aria-describedby") || "";
          this.nameInput.setAttribute(
            "aria-describedby",
            currentDesc.replace("form-error-message", "").trim(),
          );
        }
        if (this.emailInput) {
          const currentDesc =
            this.emailInput.getAttribute("aria-describedby") || "";
          this.emailInput.setAttribute(
            "aria-describedby",
            currentDesc.replace("form-error-message", "").trim(),
          );
        }
        if (this.messageInput) {
          const currentDesc =
            this.messageInput.getAttribute("aria-describedby") || "";
          this.messageInput.setAttribute(
            "aria-describedby",
            currentDesc.replace("form-error-message", "").trim(),
          );
        }
        (this.form.querySelector("input") as HTMLInputElement)?.focus();
      });

      this.errorResetBtn?.addEventListener("click", () => {
        // 🎨 Palette: Subtle tactile feedback
        if (navigator.vibrate && !prefersReducedMotionQuery.matches)
          navigator.vibrate(30);

        this.errorMessage?.classList.add("hidden");
        if (this.submitButton) {
          this.submitButton.removeAttribute("aria-disabled");
          this.submitButton.removeAttribute("aria-busy");
        }
        this.submitButton?.focus();
      });

      this.submitButton?.addEventListener("click", (e) => {
        if (this.submitButton.getAttribute("aria-disabled") === "true") return;

        // 🎨 Palette: Tactile feedback for primary action
        if (navigator.vibrate && !prefersReducedMotionQuery.matches)
          navigator.vibrate(50);

        if (prefersReducedMotionQuery.matches) return;
        const rect = this.submitButton.getBoundingClientRect();
        const ripple = document.createElement("span");
        ripple.className = "ripple-circle";
        ripple.style.width =
          ripple.style.height = `${Math.max(rect.width, rect.height)}px`;
        ripple.style.left = `${e.clientX - rect.left - rect.width / 2}px`;
        ripple.style.top = `${e.clientY - rect.top - rect.height / 2}px`;
        this.submitButton.querySelector(".btn-ripple")?.appendChild(ripple);
        setTimeout(() => ripple.remove(), 600);
      });

      this.nameInput?.addEventListener("input", () => {
        const isValid = this.nameInput.value.trim().length >= 2;
        this.updateValidationIcon(this.nameInput, isValid);

        if (this.nameInput.hasAttribute("aria-invalid") && isValid) {
          this.nameInput.removeAttribute("aria-invalid");
          const currentDesc =
            this.nameInput.getAttribute("aria-describedby") || "";
          this.nameInput.setAttribute(
            "aria-describedby",
            currentDesc.replace("form-error-message", "").trim(),
          );
          this.hideErrorIfFormIsValid();
        }
      });

      this.emailInput?.addEventListener("input", () => {
        const isValid = isValidEmail(this.emailInput.value);
        this.updateValidationIcon(this.emailInput, isValid);

        if (this.emailInput.hasAttribute("aria-invalid") && isValid) {
          this.emailInput.removeAttribute("aria-invalid");
          const currentDesc =
            this.emailInput.getAttribute("aria-describedby") || "";
          this.emailInput.setAttribute(
            "aria-describedby",
            currentDesc.replace("form-error-message", "").trim(),
          );
          this.hideErrorIfFormIsValid();
        }
      });

      this.form.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (
          this.submitButton &&
          this.submitButton.getAttribute("aria-disabled") === "true"
        ) {
          return;
        }

        const invalidEls = this.form.querySelectorAll("[aria-invalid]");
        for (let i = 0; i < invalidEls.length; i++) {
          invalidEls[i].removeAttribute("aria-invalid");
        }
        this.errorMessage?.classList.add("hidden");

        if (this.nameInput && this.nameInput.value.trim().length < 2) {
          this.nameInput.setAttribute("aria-invalid", "true");
          const currentDesc =
            this.nameInput.getAttribute("aria-describedby") || "";
          if (!currentDesc.includes("form-error-message")) {
            this.nameInput.setAttribute(
              "aria-describedby",
              currentDesc
                ? `${currentDesc} form-error-message`
                : "form-error-message",
            );
          }
          this.showError(
            "Veuillez entrer votre nom (minimum 2 caractères).",
            this.nameInput,
          );
          return;
        }

        if (this.emailInput && !isValidEmail(this.emailInput.value)) {
          this.emailInput.setAttribute("aria-invalid", "true");
          const currentDesc =
            this.emailInput.getAttribute("aria-describedby") || "";
          if (!currentDesc.includes("form-error-message")) {
            this.emailInput.setAttribute(
              "aria-describedby",
              currentDesc
                ? `${currentDesc} form-error-message`
                : "form-error-message",
            );
          }
          this.showError(
            "Veuillez entrer une adresse email valide.",
            this.emailInput,
          );
          return;
        }

        if (this.messageInput && this.messageInput.value.trim().length < 10) {
          this.messageInput.setAttribute("aria-invalid", "true");
          const currentDesc =
            this.messageInput.getAttribute("aria-describedby") || "";
          if (!currentDesc.includes("form-error-message")) {
            this.messageInput.setAttribute(
              "aria-describedby",
              currentDesc
                ? `${currentDesc} form-error-message`
                : "form-error-message",
            );
          }
          this.showError(
            "Veuillez entrer un message d'au moins 10 caractères.",
            this.messageInput,
          );
          return;
        }

        const loadTimestamp = parseInt(this.timestampInput.value, 10);
        const submitTimestamp = Date.now();
        if (submitTimestamp - loadTimestamp < 2000) {
          this.showError(
            "Le formulaire a été soumis trop rapidement. Veuillez réessayer.",
          );
          return;
        }

        try {
          const lastSubmission = localStorage.getItem(
            "contact_form_last_submission",
          );
          if (
            lastSubmission &&
            Date.now() - parseInt(lastSubmission, 10) < 120000
          ) {
            this.showError(
              "Veuillez attendre quelques minutes avant de renvoyer un message.",
            );
            return;
          }
        } catch {
          // Ignore localStorage errors
        }

        if (this.submitButton) {
          this.submitButton.classList.add("loading");
          this.submitButton.setAttribute("aria-disabled", "true");
          this.submitButton.setAttribute("aria-busy", "true");
        }

        try {
          const formData = new FormData(this.form);
          const data: Record<string, string> = {};
          if (import.meta.env.DEV) {
            try {
              const res = await fetch("/api/dev-key");
              if (res.ok) {
                const json = await res.json();
                if (json.key) data["access_key"] = json.key;
              }
            } catch (e) {
              // eslint-disable-next-line no-console
              console.error(e);
            }
          }
          const allowedFields = new Set([
            "name",
            "email",
            "message",
            "access_key",
            "subject",
            "botcheck",
            "form-load-timestamp",
          ]);

          // ⚡ Bolt: Replaced forEach with standard for...of loop to avoid callback allocation
          for (const [key, value] of formData.entries()) {
            if (allowedFields.has(key) && typeof value === "string") {
              if (key === "email") {
                data[key] = value;
              } else {
                data[key] = sanitizeInput(value);
              }
            }
          }

          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 10000);

          const submitUrl = import.meta.env.DEV
            ? "https://api.web3forms.com/submit"
            : "/api/submit";
          const response = await fetch(submitUrl, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(data),
            signal: controller.signal,
          });

          clearTimeout(timeoutId);
          const result = await response.json();

          if (result.success) {
            // 🎨 Palette: Tactile feedback for success
            if (navigator.vibrate && !prefersReducedMotionQuery.matches)
              navigator.vibrate(50);

            this.errorMessage?.classList.add("hidden");
            this.form.removeAttribute("aria-describedby");
            const successMessage = document.getElementById(
              "form-success-message",
            ) as HTMLElement;
            if (successMessage) {
              successMessage.classList.remove("hidden");
              successMessage.classList.add("flex");
              setTimeout(() => successMessage.focus(), 100);
            }
            try {
              localStorage.setItem(
                "contact_form_last_submission",
                Date.now().toString(),
              );
            } catch {
              // Ignore localStorage errors
            }
            this.form.reset();
          } else {
            throw new Error(result.message || "Submission failed");
          }
        } catch (error) {
          const isAbortError =
            error instanceof Error && error.name === "AbortError";
          if (import.meta.env.DEV) {
            // eslint-disable-next-line no-console
            console.error(
              "Form submission failed:",
              isAbortError
                ? "Request timed out"
                : error instanceof Error
                  ? error.message
                  : "Unknown error",
            );
          }

          if (this.submitButton) {
            this.submitButton.classList.remove("loading");
            this.submitButton.removeAttribute("aria-disabled");
            this.submitButton.removeAttribute("aria-busy");
          }
          this.showError(
            isAbortError
              ? "Le serveur met trop de temps à répondre. Veuillez réessayer."
              : "Une erreur est survenue. Veuillez réessayer plus tard.",
          );
          this.form.setAttribute("aria-describedby", "form-error-message");
        }
      });
    }
  }

  function initContactForm() {
    const formElement = document.getElementById(
      "contact-form",
    ) as HTMLFormElement;
    if (formElement) {
      new ContactFormController(formElement);
    }

    // 🎨 Palette: Centralized Smart Scroll & Highlight for Contact Form
    const handleSmartScroll = (e: MouseEvent | KeyboardEvent) => {
      const target = e.target as HTMLElement;
      const link = target.closest(
        'a[href="#contact-form"], a[href="#cta-section"]',
      );

      // Re-query elements inside the listener to avoid stale references in SPA
      const form = document.getElementById("contact-form") as HTMLFormElement;
      const nameInput = document.getElementById("name") as HTMLInputElement;

      if (link && form) {
        e.preventDefault();

        // Device detection (coarse pointer = touch/mobile)
        const isMobile = window.matchMedia("(pointer: coarse)").matches;

        if (isMobile) {
          // Mobile: Focus container to avoid keyboard jump
          form.setAttribute("tabindex", "-1");
          form.focus({ preventScroll: true });
          form.scrollIntoView({ behavior: "smooth", block: "start" });
        } else {
          // Desktop: Focus input for immediate typing
          if (nameInput) {
            nameInput.focus({ preventScroll: true });
            nameInput.scrollIntoView({ behavior: "smooth", block: "center" });
          } else {
            form.setAttribute("tabindex", "-1");
            form.focus({ preventScroll: true });
            form.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        }

        // Add highlight animation
        form.classList.remove("form-highlight");
        void form.offsetWidth; // Force reflow
        form.classList.add("form-highlight");
        setTimeout(() => form.classList.remove("form-highlight"), 2000);
      }
    };

    if (window.__contactScrollHandler) {
      document.removeEventListener("click", window.__contactScrollHandler);
    }
    window.__contactScrollHandler = handleSmartScroll as EventListener;
    document.addEventListener("click", window.__contactScrollHandler);
  }

  initContactForm();
  if (window.__contactInitHandler) {
    document.removeEventListener(
      "astro:page-load",
      window.__contactInitHandler,
    );
  }
  window.__contactInitHandler = initContactForm;
  document.addEventListener("astro:page-load", initContactForm);
</script>
