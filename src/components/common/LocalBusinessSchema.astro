---
import config from "../../config.mjs";
import { safeJson } from "../../utils/security";

const siteUrl = "https://portfolio.kuasar.xyz";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "@id": siteUrl + "/#business",
  name: config.title,
  alternateName: "Kuasar",
  description: config.description,
  image: siteUrl + "/defaultog.jpg",
  url: siteUrl,
  email: config.email,
  founder: {
    "@type": "Person",
    "@id": siteUrl + "/#person",
    name: "Samuel Dulex",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Lausanne",
    postalCode: config.postalCode,
    addressRegion: "VD",
    addressCountry: "CH",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 46.519653,
    longitude: 6.632273,
  },
  areaServed: [
    ...config.catchmentCities.map((name) => ({ "@type": "City", name })),
    ...config.catchmentRegions.map((name) => ({ "@type": "State", name })),
    { "@type": "AdministrativeArea", name: "Suisse romande" },
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Services",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Création de contenu",
          description:
            "Vidéo et photographie : clips, courts-métrages, reportages, photographie de plateau et d'événement, à Lausanne et en Suisse romande.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Développement web",
          description:
            "Sites, applications et plateformes performants, accessibles et sécurisés (Astro, Vue.js, Laravel, TypeScript).",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Communication",
          description:
            "Stratégie, campagnes, relations presse et promotion d'événements, de l'affiche aux réseaux sociaux.",
        },
      },
    ],
  },
  knowsAbout: [
    "Production vidéo",
    "Clips musicaux",
    "Photographie événementielle",
    "Développement web fullstack",
    "React",
    "Laravel",
    "Astro",
    "SEO",
    "Stratégie digitale",
    "Direction artistique",
  ],
  priceRange: "$$",
  paymentAccepted: "Virement bancaire, TWINT",
  currenciesAccepted: "CHF, EUR",
  sameAs: [
    config.social.instagram || "",
    config.social.github || "",
    config.social.youtube || "",
  ].filter(Boolean),
};
---

<script type="application/ld+json" is:inline set:html={safeJson(jsonLd)} />
