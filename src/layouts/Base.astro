---
import SeoHead from "../components/common/SeoHead.astro";
import LocalBusinessSchema from "../components/common/LocalBusinessSchema.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import Lightbox from "../components/ui/Lightbox.astro";
import "../css/style.css";

import { ClientRouter } from "astro:transitions";
import { getImage } from "astro:assets";
import { safeJson } from "../utils/security";
import logo from "../assets/logo.avif";

const {
  postData,
  jsonLd,
  noPadding = false,
  lang = "fr",
  noindex = false,
} = Astro.props;

// ⚡ Bolt: Precompute LCP image URL for preloading (Hero Logo)
// Changed format from "webp" to "avif" to exactly match the <img> tag in Hero.astro.
// This prevents the browser from downloading two separate image files for the LCP element.
// We only generate this on the homepage to save processing time on subpages.
const PUBLIC_CF_ANALYTICS_TOKEN = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

let heroLogoPromise: Promise<Awaited<ReturnType<typeof getImage>>> | null =
  null;
if (Astro.url.pathname === "/") {
  heroLogoPromise = getImage({ src: logo, width: 360, format: "avif" });
}

// ⚡ Bolt: Precompute LCP image for subpages (Project/Blog posts)
let lcpImagePromise: Promise<Awaited<ReturnType<typeof getImage>>> | null =
  null;
if (postData?.data?.image) {
  lcpImagePromise = getImage({
    src: postData.data.image,
    width: 1600,
    format: "webp",
  });
}

const [heroLogo, lcpImage] = await Promise.all([
  heroLogoPromise,
  lcpImagePromise,
]);

const translations = {
  fr: {
    skipContent: "Aller au contenu principal",
    skipFooter: "Aller au pied de page",
    backToTop: "Retour en haut de page",
    backToTopTooltip: "Retour en haut",
  },
  en: {
    skipContent: "Skip to main content",
    skipFooter: "Skip to footer",
    backToTop: "Back to top",
    backToTopTooltip: "Back to top",
  },
};

const t = translations[lang as keyof typeof translations] || translations.fr;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <!-- ⚡ Preconnect hints FIRST for maximum early connection (190ms+ LCP savings) -->
    <link
      rel="preconnect"
      href="https://static.cloudflareinsights.com"
      crossorigin
    />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />
    <!-- ⚡ Bolt: Downgraded non-critical third-parties to dns-prefetch to save connection slots -->
    <link rel="dns-prefetch" href="https://api.websitecarbon.com" />
    <link rel="dns-prefetch" href="https://api.web3forms.com" />
    <link rel="dns-prefetch" href="https://i.ytimg.com" />
    <link rel="dns-prefetch" href="https://www.youtube.com" />
    <link rel="dns-prefetch" href="https://vimeo.com" />
    <link rel="dns-prefetch" href="https://player.vimeo.com" />
    <style>
      @media (prefers-reduced-motion: reduce) {
        :global(html) {
          scroll-behavior: auto !important;
        }
      }
    </style>
    <!-- Font Preloads (Critical Request Chain Optimization) -->
    <link
      rel="preload"
      href="/fonts/space-grotesk-bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <!-- ⚡ Bolt: Removed fetchpriority="high" from non-LCP fonts (Light/Regular) -->
    <!-- This reduces network contention, allowing the LCP Image and Heading Font to load faster -->
    <link
      rel="preload"
      href="/fonts/outfit-light.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/outfit-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <!-- ⚡ Bolt: Added Outfit Bold preload as it's used in Hero buttons (LCP) -->
    <link
      rel="preload"
      href="/fonts/outfit-bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <!-- LCP Image Preload (Hero Logo) - Only on Homepage -->
    {
      heroLogo && (
        <link
          rel="preload"
          href={heroLogo.src}
          as="image"
          type="image/avif"
          fetchpriority="high"
        />
      )
    }

    <!-- ⚡ Bolt: LCP Image Preload (Project/Post Hero) -->
    {
      /*
      ⚡ Bolt: Fixed MIME type declaration for LCP Image preload.
      lcpImage is explicitly generated with format: "webp" in the frontmatter logic above.
      The type attribute must be "image/webp" (not "image/avif") so the browser correctly
      matches the preloaded resource with the subsequent <img> tag request, avoiding a double-fetch.
    */
    }
    {
      lcpImage && (
        <link
          rel="preload"
          href={lcpImage.src}
          as="image"
          type="image/webp"
          fetchpriority="high"
        />
      )
    }

    <!-- ⚡ Bolt: Speculation Rules API for instant navigation -->
    <script
      type="speculationrules"
      is:inline
      set:html={safeJson({
        prerender: [
          {
            source: "document",
            where: {
              href_matches: "/*",
            },
            eagerness: "moderate",
          },
        ],
      })}
    />
    <style is:global>
      /* Manual Font Face Definitions */
      @font-face {
        font-family: "Space Grotesk";
        src: url("/fonts/space-grotesk-bold.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Outfit";
        src: url("/fonts/outfit-light.woff2") format("woff2");
        font-weight: 300;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Outfit";
        src: url("/fonts/outfit-regular.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Outfit";
        src: url("/fonts/outfit-bold.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
    </style>
    <!-- Critical preconnects - must be early in head for effectiveness -->
    <meta name="theme-color" content="#f8fafc" />
    <script is:inline>
      // ⚡ Bolt: Cache matchMedia outside function to avoid re-parsing on every navigation
      const prefersDarkQuery = window.matchMedia(
        "(prefers-color-scheme: dark)",
      );

      const applyTheme = () => {
        if (
          localStorage.getItem("theme") === "dark" ||
          (!localStorage.getItem("theme") && prefersDarkQuery.matches)
        ) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      };

      // Early theme detection to prevent FOUC
      applyTheme();

      // Re-apply theme across View Transitions
      document.addEventListener("astro:after-swap", applyTheme);
    </script>
    <SeoHead postData={postData} jsonLd={jsonLd} noindex={noindex} />
    <LocalBusinessSchema />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <ClientRouter />
  </head>
  <body
    class="bg-pacamara-white dark:bg-pacamara-dark transition-colors duration-300 min-h-screen flex flex-col relative"
  >
    <!-- Scroll Sentinel for Back to Top visibility -->
    <div
      id="scroll-sentinel"
      class="absolute top-0 w-full h-[300px] pointer-events-none -z-50"
      style="contain: strict;"
      aria-hidden="true"
    >
    </div>

    <!-- 🎨 Palette: Accessible Skip Links -->
    <div class="absolute z-100 top-0 left-0 pointer-events-none">
      <a
        href="#main-content"
        class="skip-link absolute left-4 top-4 -translate-y-[150%] focus-visible:translate-y-0 transition-transform duration-300 ease-out px-6 py-3 bg-white text-pacamara-primary font-bold rounded-full shadow-lg border border-pacamara-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 pointer-events-auto"
        data-haptic="30"
      >
        {t.skipContent}
      </a>
      <a
        href="#main-footer"
        class="skip-link absolute left-4 top-4 -translate-y-[150%] focus-visible:translate-y-0 transition-transform duration-300 ease-out px-6 py-3 bg-white text-pacamara-primary font-bold rounded-full shadow-lg border border-pacamara-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 pointer-events-auto"
        data-haptic="30"
      >
        {t.skipFooter}
      </a>
    </div>
    <Header />

    <main
      id="main-content"
      class={`grow ${noPadding ? "" : "pt-24"}`}
      transition:animate="fade"
      tabindex="-1"
      style="contain: layout;"
    >
      <slot />
    </main>

    <Footer />

    <!-- Lightbox at body level for proper fixed positioning -->
    <Lightbox />

    <!-- Back to Top Button -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-50 w-12 h-12 flex items-center justify-center rounded-full bg-pacamara-secondary/90 text-white shadow-lg hover:bg-pacamara-accent transition-all duration-300 opacity-0 invisible translate-y-4 hover-lift focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2 group cursor-pointer"
      aria-label={t.backToTop}
      tabindex="-1"
    >
      <span
        class="absolute right-full mr-4 px-2 py-1 bg-pacamara-dark/90 dark:bg-white/90 text-white dark:text-pacamara-dark text-xs rounded opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity whitespace-nowrap pointer-events-none"
        aria-hidden="true"
      >
        {t.backToTopTooltip}
        <span
          class="absolute left-full top-1/2 -translate-y-1/2 w-0 h-0 border-y-4 border-y-transparent border-l-[5px] border-l-pacamara-dark/90 dark:border-l-white/90"
        ></span>
      </span>
      <!-- 🎨 Palette: Circular Progress Indicator -->
      <svg
        class="absolute inset-0 w-full h-full -rotate-90 pointer-events-none p-0.5"
        viewBox="0 0 36 36"
        aria-hidden="true"
      >
        <!-- Track -->
        <path
          class="text-white/20"
          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
          fill="none"
          stroke="currentColor"
          stroke-width="3"></path>
        <!-- Progress -->
        <path
          id="scroll-progress-circle"
          class="text-white transition-all duration-100 ease-out"
          stroke-dasharray="100, 100"
          stroke-dashoffset="100"
          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"></path>
      </svg>

      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="relative z-10 h-5 w-5 transition-transform duration-300 group-hover:-translate-y-0.5 group-focus-visible:-translate-y-0.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2.5"
          d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
      </svg>
    </button>

    <script>
      // ⚡ Bolt: Cache matchMedia globally to avoid re-parsing on every navigation and component initialization
      const prefersReducedMotionQuery = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      );

      /**
       * ⚡ Bolt: Back to Top Performance Optimization
       * - Implements cleanup pattern to prevent event listener leaks on navigation
       * - Caches layout metrics to avoid layout thrashing in scroll handler
       * - Throttles scroll updates using requestAnimationFrame
       */
      function initBackToTop() {
        // ⚡ Cleanup previous listeners before initializing new ones
        if (window.__cleanupBackToTop) {
          window.__cleanupBackToTop();
          window.__cleanupBackToTop = null;
        }

        const backToTopBtn = document.getElementById("back-to-top");
        const sentinel = document.getElementById("scroll-sentinel");
        const progressCircle = document.getElementById(
          "scroll-progress-circle",
        );

        // ⚡ Early return if elements don't exist
        if (!backToTopBtn || !sentinel || !progressCircle) return;

        // ⚡ RAF ID for animation tracking
        let rafId: number | null = null;
        // ⚡ Bolt: Cache document height to avoid layout thrashing
        let cachedDocHeight = 0;

        let backToTopObserver: IntersectionObserver | null = null;

        // ⚡ Bolt: RAF throttling state
        let ticking = false;

        // ⚡ Bolt: Efficiently update dimensions only when they change
        const updateDimensions = () => {
          cachedDocHeight =
            document.documentElement.scrollHeight -
            document.documentElement.clientHeight;
        };

        // 🎨 Palette: Scroll Progress Logic with RAF throttling
        const updateVisuals = () => {
          if (!progressCircle) return;
          const scrollTop = window.scrollY;

          // ⚡ Bolt: Use cached height instead of querying DOM (prevents reflow)
          const scrollPercent =
            cachedDocHeight > 0 ? Math.min(scrollTop / cachedDocHeight, 1) : 0;
          const draw = scrollPercent * 100;
          progressCircle.style.strokeDashoffset = (100 - draw).toString();
          ticking = false;
        };

        const onScroll = () => {
          if (!ticking) {
            window.requestAnimationFrame(updateVisuals);
            ticking = true;
          }
        };

        // Update visual state (deferred until button is visible)
        // ⚡ Bolt: Listen to global app:resize event instead of local ResizeObserver
        const onResize = () => {
          updateDimensions();
          // Update visuals immediately in case scroll pos stayed same but height changed
          window.requestAnimationFrame(updateVisuals);
        };
        window.addEventListener("app:resize", onResize);

        // Initial calculation
        updateDimensions();
        updateVisuals();

        // ⚡ Early return if already initialized
        if (backToTopBtn.dataset.initialized === "true") return;
        backToTopBtn.dataset.initialized = "true";

        backToTopObserver = new IntersectionObserver(
          (entries) => {
            const entry = entries[0];
            const btn = document.getElementById("back-to-top");
            if (!btn) return;

            // If sentinel is NOT intersecting (scrolled past), show button
            if (!entry.isIntersecting) {
              btn.classList.remove("opacity-0", "invisible", "translate-y-4");
              btn.classList.add("visible", "translate-y-0");
              btn.setAttribute("tabindex", "0");
              // ⚡ Bolt: Only listen to scroll when button is visible to save resources
              window.addEventListener("scroll", onScroll, { passive: true });
              onScroll(); // Update visuals immediately
            } else {
              btn.classList.add("opacity-0", "invisible", "translate-y-4");
              btn.classList.remove("visible", "translate-y-0");
              btn.setAttribute("tabindex", "-1");
              // ⚡ Bolt: Detach listener when button is hidden to save main thread
              window.removeEventListener("scroll", onScroll);
            }
          },
          {
            root: null, // viewport
            threshold: 0,
          },
        );

        backToTopObserver.observe(sentinel);

        // Scroll to top action
        const onClick = () => {
          // 🎨 Palette: Provide subtle haptic feedback for mobile users
          if (navigator.vibrate && !prefersReducedMotionQuery.matches) {
            navigator.vibrate(50);
          }
          window.scrollTo({ top: 0, behavior: "smooth" });
          const main = document.getElementById("main-content");
          if (main) {
            if (!main.hasAttribute("tabindex")) {
              main.setAttribute("tabindex", "-1");
            }
            main.focus({ preventScroll: true });
          }
        };
        backToTopBtn.addEventListener("click", onClick);

        // ⚡ Register cleanup
        window.__cleanupBackToTop = () => {
          window.removeEventListener("scroll", onScroll);
          window.removeEventListener("app:resize", onResize);
          if (backToTopObserver) {
            backToTopObserver.disconnect();
            backToTopObserver = null;
          }
          backToTopBtn.removeEventListener("click", onClick);
          if (rafId) cancelAnimationFrame(rafId);
        };
      }

      // Update theme-color meta tag based on current theme
      function updateThemeColor() {
        const isDark = document.documentElement.classList.contains("dark");
        const meta = document.querySelector('meta[name="theme-color"]');
        if (meta) {
          meta.setAttribute("content", isDark ? "#0b0f19" : "#f8fafc");
        }
      }

      // ⚡ Bolt: Global ResizeObserver Singleton
      // Replaces multiple ResizeObservers across components observing document.documentElement
      // with a single instance that dispatches a custom event, reducing memory overhead and layout thrashing.
      function initGlobalResizeObserver() {
        if (window.__globalResizeObserver) return;

        window.__globalResizeObserver = new ResizeObserver(() => {
          window.dispatchEvent(new CustomEvent("app:resize"));
        });
        window.__globalResizeObserver.observe(document.documentElement);
      }

      // ⚡ Bolt: Theme Color Observer (Singleton Pattern)
      function initThemeObserver() {
        if (window.__themeObserver) return; // Already initialized global observer

        // Initial sync of theme color on load
        updateThemeColor();

        window.__themeObserver = new MutationObserver((mutations) => {
          // ⚡ Bolt: Optimized forEach loop into a standard for loop to avoid array callback allocation.
          for (let i = 0; i < mutations.length; i++) {
            if (mutations[i].attributeName === "class") {
              updateThemeColor();
            }
          }
        });

        window.__themeObserver.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }

      // 🛡️ Sentinel: Prevent Reverse Tabnabbing & 🎨 Palette: Accessibility
      // Ensures all external links opening in a new tab have rel="noopener noreferrer"
      // and a warning in title/aria-label.
      const warning = " (ouvre un nouvel onglet)";

      /**
       * 🎨 Palette: Global Haptic Feedback
       * Centrally manages tactile feedback for interactive elements with data-haptic.
       */
      function initHaptics() {
        if (window.__hapticsInitialized) return;
        window.__hapticsInitialized = true;

        document.addEventListener("click", (e) => {
          const target = e.target as HTMLElement;
          const hapticEl = target.closest("[data-haptic]");
          if (
            hapticEl &&
            navigator.vibrate &&
            !prefersReducedMotionQuery.matches
          ) {
            const duration = parseInt(
              hapticEl.getAttribute("data-haptic") || "30",
              10,
            );
            navigator.vibrate(duration);
          }
        });
      }

      function secureLink(link: Element) {
        if (link.tagName !== "A" || link.getAttribute("target") !== "_blank")
          return;

        // 🛡️ Sentinel: Robustly ensure both noopener and noreferrer are present
        const rel = link.getAttribute("rel") || "";
        const relValues = new Set(rel.split(" ").filter(Boolean));
        relValues.add("noopener");
        relValues.add("noreferrer");
        link.setAttribute("rel", Array.from(relValues).join(" "));

        // Accessibility: Append warning to title
        const title = link.getAttribute("title") || "";
        if (!title.includes(warning.trim())) {
          link.setAttribute("title", title ? title + warning : warning.trim());
        }

        // Accessibility: Append warning to aria-label (only if present)
        const ariaLabel = link.getAttribute("aria-label");
        if (ariaLabel) {
          if (!ariaLabel.includes(warning.trim())) {
            link.setAttribute("aria-label", ariaLabel + warning);
          }
        } else {
          // 🎨 Palette: If no aria-label, inject SR-only span to preserve accessible name calculation (text + alt)
          if (!link.querySelector(".external-link-warning")) {
            const span = document.createElement("span");
            span.className = "sr-only external-link-warning";
            span.textContent = warning;
            link.appendChild(span);
          }
        }
      }

      function secureLinks() {
        // ⚡ Bolt: Removed expensive MutationObserver(subtree: true) on body.
        // Links are now secured only on initial load and navigation (astro:page-load),
        // effectively reducing main-thread CPU usage during general interaction.
        // Dynamic components (Footer, etc.) handle their own link security.
        // ⚡ Bolt: Optimized query by filtering out already-secured links using CSS :not()
        // This significantly reduces redundant JS execution and main-thread work on View Transitions.
        // ⚡ Bolt: Optimized forEach loop into a standard for loop to avoid array callback allocation.
        // ⚡ Bolt: Optimize client-side DOM query in performance-sensitive context
        // Replaced complex CSS attribute selector with getElementsByTagName and internal loop filter
        const links = document.getElementsByTagName("a");
        for (let i = 0; i < links.length; i++) {
          const link = links[i];
          if (link.getAttribute("target") === "_blank") {
            const rel = link.getAttribute("rel");
            if (!rel || !rel.includes("noopener")) {
              secureLink(link);
            }
          }
        }
      }

      // ⚡ Bolt: Singleton Listener Pattern for Base Scripts
      function setupBaseListeners() {
        const initAll = () => {
          initGlobalResizeObserver();
          initBackToTop();
          initHaptics();
          secureLinks();
          initThemeObserver();
        };

        if (window.__baseInitHandler) {
          document.removeEventListener(
            "astro:page-load",
            window.__baseInitHandler,
          );
        }

        window.__baseInitHandler = initAll;
        document.addEventListener("astro:page-load", initAll);

        // Run immediately
        initAll();
      }

      setupBaseListeners();
    </script>
    <script>
      /**
       * ⚡ Bolt: Global Background Animation Optimizer
       * Pauses infinite CSS animations (.floating, .floating-slow) when elements
       * are off-screen to save GPU memory and CPU cycles.
       * ⚡ Bolt: Centralized .infinite-scroll (carousel) and .hero-gradient-vibrant to reuse a single observer instead of creating multiple instances across components.
       */
      function initAnimationOptimizer() {
        // Disconnect previous observer
        if (window.__animationObserver) {
          window.__animationObserver.disconnect();
          window.__animationObserver = null;
        }

        // Select all floating elements
        const animatedElements = document.querySelectorAll(
          ".floating, .floating-slow, .floating-delayed, .infinite-scroll, .hero-gradient-vibrant",
        );

        if (animatedElements.length === 0) return;

        window.__animationObserver = new IntersectionObserver(
          (entries) => {
            for (let i = 0; i < entries.length; i++) {
              if (!entries[i].isIntersecting) {
                entries[i].target.classList.add("paused");
              } else {
                entries[i].target.classList.remove("paused");
              }
            }
          },
          { rootMargin: "200px" }, // Pre-load slightly before viewport
        );

        for (let i = 0; i < animatedElements.length; i++) {
          window.__animationObserver?.observe(animatedElements[i]);
        }
      }

      // ⚡ Bolt: Singleton Listener Pattern for Animation Optimizer
      function setupAnimationListeners() {
        if (window.__animInitHandler) {
          document.removeEventListener(
            "astro:after-swap",
            window.__animInitHandler,
          );
        }

        window.__animInitHandler = initAnimationOptimizer;
        document.addEventListener("astro:after-swap", initAnimationOptimizer);

        // Run immediately
        initAnimationOptimizer();
      }

      setupAnimationListeners();
    </script>
    <script>
      import { registerSW } from "virtual:pwa-register";

      if ("serviceWorker" in navigator) {
        registerSW({
          immediate: true,
        });
      }
    </script>
    <!-- Cloudflare Web Analytics -->
    {
      PUBLIC_CF_ANALYTICS_TOKEN && PUBLIC_CF_ANALYTICS_TOKEN !== "dry_run" && (
        <script
          defer
          is:inline
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={safeJson({
            token: PUBLIC_CF_ANALYTICS_TOKEN,
          })}
        />
      )
    }
    <!-- End Cloudflare Web Analytics -->
  </body>
</html>
