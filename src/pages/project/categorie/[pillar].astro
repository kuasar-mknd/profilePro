---
import { getSortedProjects } from "../../../utils/projects";
import {
  PILLARS,
  pillarCounts,
  projectsOfPillar,
} from "../../../utils/pillars";
import Base from "../../../layouts/Base.astro";
import Post from "../../../components/features/projects/Post.astro";
import ProjectFilter from "../../../components/features/projects/ProjectFilter.astro";
import ScrollReveal from "../../../components/ui/ScrollReveal.astro";
import Breadcrumbs from "../../../components/ui/Breadcrumbs.astro";
import EmptyState from "../../../components/ui/EmptyState.astro";

export async function getStaticPaths() {
  const allProjects = await getSortedProjects();
  const counts = pillarCounts(allProjects);

  return PILLARS.map((pillar) => ({
    params: { pillar: pillar.slug },
    props: {
      pillar,
      projects: projectsOfPillar(allProjects, pillar),
      counts,
      totalCount: allProjects.length,
    },
  }));
}

const { pillar, projects, counts, totalCount } = Astro.props;

const title = `Réalisations en ${pillar.label.toLowerCase()}`;
const description = pillar.description;
---

<Base postData={{ data: { title, description } }}>
  <section class="container mx-auto max-w-7xl px-7 pt-10 pb-14">
    <ScrollReveal class="text-center mb-10">
      <Breadcrumbs
        items={[
          { label: "Accueil", href: "/" },
          { label: "Projets", href: "/project/" },
          { label: pillar.label },
        ]}
      />
      <h1
        class="text-3xl md:text-5xl font-pacamara-space font-bold mb-4 text-pacamara-dark dark:text-white relative inline-block"
      >
        {pillar.label}
        <span
          class="ml-2 px-3 py-1 text-sm bg-pacamara-accent/10 text-pacamara-accent rounded-full align-middle font-outfit"
        >
          {counts[pillar.slug]}
        </span>
      </h1>
      <p
        class="text-lg text-pacamara-primary/70 dark:text-white/70 font-outfit max-w-2xl mx-auto mb-8"
      >
        {pillar.description}
      </p>
      <ProjectFilter
        activePillar={pillar.slug}
        counts={counts}
        totalCount={totalCount}
      />
    </ScrollReveal>

    <div
      class="flex flex-wrap justify-center gap-8 mb-16 [content-visibility:auto] [contain-intrinsic-size:auto_2000px] contain-layout"
    >
      {
        projects.length === 0 ? (
          <EmptyState
            message={`Aucun projet dans le pilier « ${pillar.label} » pour le moment.`}
            actionUrl="/project/"
            actionText="Voir tous les projets"
          />
        ) : (
          projects.map((post, index) => (
            <ScrollReveal
              delay={index * 0.1}
              class="w-full md:w-[calc(50%-1rem)]"
            >
              <Post postData={post} num={index} priority={index < 2} />
            </ScrollReveal>
          ))
        )
      }
    </div>
  </section>
</Base>
