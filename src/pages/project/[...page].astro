---
import type { Page, PaginateFunction } from "astro";
import type { CollectionEntry } from "astro:content";
import config from "../../config.mjs";
import { getSortedProjects } from "../../utils/projects";

import Base from "../../layouts/Base.astro";
import { safeJson } from "../../utils/security";
import Post from "../../components/features/projects/Post.astro";
import ProjectFilter from "../../components/features/projects/ProjectFilter.astro";
import ScrollReveal from "../../components/ui/ScrollReveal.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import { sanitizeUrl } from "../../utils/security";
import { Icon } from "astro-icon/components";

export async function getStaticPaths({
  paginate,
}: {
  paginate: PaginateFunction;
}) {
  const allProjects = await getSortedProjects();

  // ⚡ Bolt: Calculate unique tags and tag counts in a single O(N) pass
  // This avoids redundant array allocations from .map().flat() and O(P*N) calculations
  const tagCounts: Record<string, number> = {};
  const uniqueTagsSet = new Set<string>();

  for (let i = 0; i < allProjects.length; i++) {
    const projectTags = allProjects[i].data.tag;
    if (Array.isArray(projectTags)) {
      for (let j = 0; j < projectTags.length; j++) {
        const tag = projectTags[j];
        uniqueTagsSet.add(tag);
        tagCounts[tag] = (tagCounts[tag] || 0) + 1;
      }
    } else {
      const tag = projectTags as string;
      uniqueTagsSet.add(tag);
      tagCounts[tag] = (tagCounts[tag] || 0) + 1;
    }
  }

  const uniqueTags = Array.from(uniqueTagsSet);
  const projectEntries = allProjects;

  return paginate(projectEntries, {
    pageSize: config.postsPerPage,
    props: { allTags: uniqueTags, tagCounts, totalCount: allProjects.length },
  });
}

export interface Props {
  page: Page<CollectionEntry<"project">>;
  allTags: string[];
  tagCounts: Record<string, number>;
  totalCount: number;
}

const { page, allTags, tagCounts, totalCount } = Astro.props;

const siteUrl = "https://portfolio.kuasar.xyz";
const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Projets — Samuel Dulex",
  description:
    "Collection complète des réalisations de Samuel Dulex en production vidéo, photographie et développement web à Lausanne, Suisse romande.",
  url: siteUrl + "/project/",
  isPartOf: { "@id": siteUrl + "/#website" },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: totalCount,
    itemListElement: page.data.map((project, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: siteUrl + `/project/${project.slug}/`,
      name: project.data.title,
    })),
  },
};
---

<Base
  postData={{
    data: {
      title: "Projets",
      description:
        "Collection de projets en production vidéo, photographie et développement web par Samuel Dulex, basé à Lausanne.",
    },
  }}
  jsonLd={collectionJsonLd}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={safeJson(collectionJsonLd)}
  />
  <section class="container mx-auto max-w-7xl px-7 pt-10 pb-20">
    <ScrollReveal class="text-center mb-10">
      <Breadcrumbs
        items={[{ label: "Accueil", href: "/" }, { label: "Projets" }]}
      />
      <h1
        class="text-3xl md:text-5xl font-pacamara-space font-bold mb-6 text-pacamara-dark dark:text-white relative inline-block"
      >
        Toutes les <span class="text-shimmer">Réalisations</span>
      </h1>
      <p
        class="text-lg text-pacamara-primary/70 dark:text-white/70 font-outfit max-w-2xl mx-auto mb-8"
      >
        Une collection de mes projets récents en vidéo, photo et développement.
      </p>
      <ProjectFilter
        tags={allTags}
        tagCounts={tagCounts}
        totalCount={totalCount}
      />
    </ScrollReveal>
    {
      /* ⚡ Bolt: Performance Optimization - content-visibility skips rendering when off-screen */
    }
    <div
      class="flex flex-wrap justify-center gap-8 mb-16"
      style="content-visibility: auto; contain-intrinsic-size: auto 1500px;"
    >
      {
        page.data.length === 0 ? (
          <EmptyState
            message="Aucun projet trouvé pour le moment."
            actionUrl="/"
            actionText="Retour à l'accueil"
          />
        ) : (
          page.data.map((post, index) => {
            return (
              <ScrollReveal
                delay={index * 0.1}
                class="w-full md:w-[calc(50%-1rem)]"
              >
                <Post postData={post} num={index} priority={index < 2} />
              </ScrollReveal>
            );
          })
        )
      }
    </div>
    {
      page.lastPage > 1 && (
        <nav
          class="flex flex-col md:flex-row items-center justify-center gap-6 mt-8"
          aria-label="Pagination des projets"
        >
          <div class="flex items-center gap-4">
            {page.url.prev ? (
              <a
                id="prev-page-link"
                href={sanitizeUrl(page.url.prev)}
                class="group flex items-center gap-2 text-base bg-transparent border border-pacamara-secondary leading-none rounded-full py-3 px-6 text-pacamara-secondary hover:bg-pacamara-accent hover:border-pacamara-accent hover:text-pacamara-white transition-all duration-300 font-pacamara-space font-bold hover-scale-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2"
                aria-label={`Précédent (page ${page.currentPage - 1}) ([)`}
                aria-keyshortcuts="["
                data-haptic="30"
              >
                <Icon
                  name="mdi:arrow-left"
                  class="w-5 h-5 transition-transform group-hover:-translate-x-1 group-focus-visible:-translate-x-1"
                  aria-hidden="true"
                />
                <span>Précédent</span>
                <kbd
                  class="font-sans ml-1 opacity-70 hidden sm:inline-block text-[10px] bg-pacamara-primary/5 dark:bg-white/10 px-1.5 py-0.5 rounded"
                  aria-hidden="true"
                >
                  [
                </kbd>
              </a>
            ) : (
              <span
                class="flex items-center gap-2 text-base bg-transparent border border-pacamara-secondary/30 leading-none rounded-full py-3 px-6 text-pacamara-secondary/30 font-pacamara-space font-bold cursor-not-allowed select-none"
                aria-disabled="true"
              >
                <Icon
                  name="mdi:arrow-left"
                  class="w-5 h-5 opacity-50"
                  aria-hidden="true"
                />
                <span>Précédent</span>
                <kbd
                  class="font-sans ml-1 opacity-70 hidden sm:inline-block text-[10px] bg-pacamara-primary/5 dark:bg-white/10 px-1.5 py-0.5 rounded"
                  aria-hidden="true"
                >
                  [
                </kbd>
              </span>
            )}

            {page.url.next ? (
              <a
                id="next-page-link"
                href={sanitizeUrl(page.url.next)}
                class="group flex items-center gap-2 text-base bg-transparent border border-pacamara-secondary leading-none rounded-full py-3 px-6 text-pacamara-secondary hover:bg-pacamara-accent hover:border-pacamara-accent hover:text-pacamara-white transition-all duration-300 font-pacamara-space font-bold hover-scale-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2"
                aria-label={`Suivant (page ${page.currentPage + 1}) (])`}
                aria-keyshortcuts="]"
                data-haptic="30"
              >
                <span>Suivant</span>
                <kbd
                  class="font-sans ml-1 opacity-70 hidden sm:inline-block text-[10px] bg-pacamara-primary/5 dark:bg-white/10 px-1.5 py-0.5 rounded"
                  aria-hidden="true"
                >
                  ]
                </kbd>
                <Icon
                  name="mdi:arrow-right"
                  class="w-5 h-5 transition-transform group-hover:translate-x-1 group-focus-visible:translate-x-1"
                  aria-hidden="true"
                />
              </a>
            ) : (
              <span
                class="flex items-center gap-2 text-base bg-transparent border border-pacamara-secondary/30 leading-none rounded-full py-3 px-6 text-pacamara-secondary/30 font-pacamara-space font-bold cursor-not-allowed select-none"
                aria-disabled="true"
              >
                <span>Suivant</span>
                <kbd
                  class="font-sans ml-1 opacity-70 hidden sm:inline-block text-[10px] bg-pacamara-primary/5 dark:bg-white/10 px-1.5 py-0.5 rounded"
                  aria-hidden="true"
                >
                  ]
                </kbd>
                <Icon
                  name="mdi:arrow-right"
                  class="w-5 h-5 opacity-50"
                  aria-hidden="true"
                />
              </span>
            )}
          </div>

          <div
            class="text-sm font-outfit text-pacamara-primary/60 dark:text-white/60 bg-pacamara-primary/5 dark:bg-white/5 px-4 py-2 rounded-full border border-pacamara-primary/10 dark:border-white/10"
            aria-live="polite"
          >
            Page{" "}
            <span class="font-bold text-pacamara-accent">
              {page.currentPage}
            </span>{" "}
            sur{" "}
            <span class="font-medium text-pacamara-primary dark:text-white">
              {page.lastPage}
            </span>
          </div>
        </nav>
      )
    }
  </section>
</Base>

<script>
  /**
   * 🎨 Palette: Pagination Keyboard Shortcuts
   * - [ : Previous Page
   * - ] : Next Page
   */
  function initPaginationInteractions() {
    const prevLink = document.getElementById(
      "prev-page-link",
    ) as HTMLAnchorElement;
    const nextLink = document.getElementById(
      "next-page-link",
    ) as HTMLAnchorElement;

    const handlePaginationKeydown = (e: KeyboardEvent) => {
      const target = e.target as HTMLElement;

      if (
        target.tagName === "INPUT" ||
        target.tagName === "SELECT" ||
        target.tagName === "TEXTAREA" ||
        target.isContentEditable
      ) {
        return;
      }

      if (e.ctrlKey || e.metaKey || e.altKey || e.shiftKey) {
        return;
      }

      if (e.key === "[") {
        if (prevLink) {
          e.preventDefault();
          prevLink.click();
        }
      } else if (e.key === "]") {
        if (nextLink) {
          e.preventDefault();
          nextLink.click();
        }
      }
    };

    if (window.__paginationKeydownHandler) {
      document.removeEventListener(
        "keydown",
        window.__paginationKeydownHandler,
      );
    }
    window.__paginationKeydownHandler = handlePaginationKeydown;
    document.addEventListener("keydown", window.__paginationKeydownHandler);
  }

  if (window.__paginationInteractionsInitHandler) {
    document.removeEventListener(
      "astro:page-load",
      window.__paginationInteractionsInitHandler,
    );
  }
  window.__paginationInteractionsInitHandler = initPaginationInteractions;
  document.addEventListener("astro:page-load", initPaginationInteractions);
  initPaginationInteractions();
</script>
