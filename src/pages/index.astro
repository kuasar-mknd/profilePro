---
import { getSortedProjects } from "../utils/projects";
import { selectFeaturedBalanced } from "../utils/featured";
import Base from "../layouts/Base.astro";
import Hero from "../components/features/home/Hero.astro";
import ServicesPreview from "../components/features/home/ServicesPreview.astro";
import LatestPosts from "../components/features/projects/LatestPosts.astro";
import CTASection from "../components/common/CTASection.astro";
import config from "../config.mjs";

const allProjects = await getSortedProjects();

// Sélection éditoriale équilibrée entre les piliers (vidéo, photo, web,
// communication) plutôt que les 7 plus récents, qui étaient presque
// toujours des projets vidéo.
const featuredSelection = selectFeaturedBalanced(allProjects, 7);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://portfolio.kuasar.xyz/#person",
  name: config.title,
  url: "https://portfolio.kuasar.xyz",
  image: "https://portfolio.kuasar.xyz/defaultog.jpg",
  email: config.email,
  sameAs: [
    config.social.instagram,
    config.social.github,
    config.social.youtube,
    config.social.linkedin,
  ].filter(Boolean),
  jobTitle: "Créateur de contenu & Développeur Web",
  description:
    "Vidéaste, photographe et développeur web freelance basé à Lausanne, Suisse romande. Spécialisé en production vidéo, photographie événementielle, développement fullstack et stratégie digitale.",
  knowsAbout: [
    "Production vidéo",
    "Clips musicaux",
    "Aftermovies",
    "Photographie événementielle",
    "Photographie de plateau",
    "Développement web fullstack",
    "React",
    "Laravel",
    "Astro",
    "SEO",
    "Stratégie digitale",
    "Direction artistique",
  ],
  hasOccupation: [
    {
      "@type": "Occupation",
      name: "Vidéaste / Réalisateur",
      occupationalCategory: "27-4031",
    },
    {
      "@type": "Occupation",
      name: "Photographe",
      occupationalCategory: "27-4021",
    },
    {
      "@type": "Occupation",
      name: "Développeur Web Fullstack",
      occupationalCategory: "15-1254",
    },
  ],
  worksFor: {
    "@type": "Organization",
    name: "Indépendant",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Lausanne",
    postalCode: config.postalCode,
    addressRegion: "Vaud",
    addressCountry: "CH",
  },
  areaServed: [
    ...config.catchmentCities.map((name) => ({ "@type": "City", name })),
    ...config.catchmentRegions.map((name) => ({ "@type": "State", name })),
    { "@type": "AdministrativeArea", name: "Suisse romande" },
  ],
};
---

<Base jsonLd={jsonLd}>
  <main>
    <Hero />
    <ServicesPreview />
    {/* ⚡ Bolt: Lazy load below-the-fold images to prioritize Hero LCP */}
    <LatestPosts
      postLimit={7}
      posts={featuredSelection}
      allPosts={allProjects}
      title="Projets sélectionnés"
      subtitle="Vidéo, photographie, web et communication : une sélection représentative de mes réalisations."
      lazyLoadImages={true}
    />
    <CTASection />
  </main>
</Base>
