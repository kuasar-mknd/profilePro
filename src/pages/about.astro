---
import Base from "../layouts/Base.astro";
import { safeJson } from "../utils/security";
import { getImage } from "astro:assets";
import logo from "../assets/logo.avif";
import CTASection from "../components/common/CTASection.astro";
import { Icon } from "astro-icon/components";
import ScrollReveal from "../components/ui/ScrollReveal.astro";
import TiltCard from "../components/ui/TiltCard.astro";

const title = "À propos de moi";
const description =
  "Vidéaste, Photographe & Développeur Web. Je crée des expériences visuelles et digitales uniques.";

const [w350, w700] = await Promise.all([
  getImage({ src: logo, width: 350, format: "webp", quality: 75 }),
  getImage({ src: logo, width: 700, format: "webp", quality: 75 }),
]);

const services = [
  {
    title: "Production Vidéo",
    description:
      "Clips musicaux, aftermovies captivants et vidéos corporate dynamiques. Je mets un point d'honneur à retranscrire l'énergie brute de l'instant à travers une direction artistique et direction photo authentique au rendu esthétique.",
    icon: "mdi:video-vintage",
    color: "text-purple-500",
    gradient: "from-purple-500/20 to-purple-600/10",
  },
  {
    title: "Développement Web",
    description:
      "Applications web complexes, plateformes SaaS interactives et sites vitrines de pointe. Je conçois des écosystèmes fluides, rapides et sécurisés, conçus pour offrir la meilleure expérience utilisateur possible dès la première seconde.",
    icon: "mdi:code-tags",
    color: "text-blue-500",
    gradient: "from-blue-500/20 to-blue-600/10",
  },
  {
    title: "Photographie",
    description:
      "Portraits de caractère, photographie événementielle et lifestyle. Derrière chaque prise de vue, l'objectif est de capturer des images fortes qui racontent une histoire viscérale et subliment durablement votre image de marque.",
    icon: "mdi:camera",
    color: "text-pink-500",
    gradient: "from-pink-500/20 to-pink-600/10",
  },
  {
    title: "Stratégie Digitale",
    description:
      "Optimisation SEO, campagnes publicitaires, Social Ads percutants. Je booste votre visibilité en ligne au moyen de stratégies d'acquisition ciblées afin de convertir votre audience en clientèle engagée sur le long terme.",
    icon: "mdi:google-analytics",
    color: "text-orange-500",
    gradient: "from-orange-500/20 to-orange-600/10",
  },
];

const skills = [
  // Web & Dev
  { name: "Astro", icon: "mdi:rocket-launch" },
  { name: "Vue.js", icon: "mdi:vuejs" },
  { name: "React", icon: "mdi:react" },
  { name: "Laravel", icon: "mdi:laravel" },
  { name: "Tailwind CSS", icon: "mdi:tailwind" },
  { name: "TypeScript", icon: "mdi:language-typescript" },
  // Design & Création Visuelle
  { name: "Figma", icon: "mdi:vector-square" },
  { name: "UX / UI Design", icon: "mdi:monitor-dashboard" },
  { name: "Adobe Photoshop", icon: "mdi:palette" },
  { name: "DaVinci Resolve", icon: "mdi:video-vintage" },
  { name: "Lightroom", icon: "mdi:image-edit" },
  { name: "Prise de vue", icon: "mdi:camera-iris" },
  // Marketing & Stratégie
  { name: "Stratégie de Contenu", icon: "mdi:lightbulb-on" },
  { name: "Copywriting", icon: "mdi:pen" },
  { name: "Email Marketing & CRM", icon: "mdi:email-outline" },
  { name: "Social Media Management", icon: "mdi:share-variant" },
  { name: "Google Ads & Meta Ads", icon: "mdi:bullhorn-outline" },
  { name: "SEO & Analytics", icon: "mdi:chart-line" },
];
const siteUrl = "https://portfolio.kuasar.xyz";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  mainEntity: {
    "@type": "Person",
    "@id": siteUrl + "/#person",
    name: "Samuel Dulex",
    alternateName: "Kuasar",
    url: siteUrl,
    image: siteUrl + "/defaultog.jpg",
    jobTitle: "Créateur de contenu visuel & Développeur Web",
    description:
      "Vidéaste, photographe et développeur web freelance basé à Lausanne, Suisse romande.",
    email: "samuel@edulex.ch",
    knowsAbout: [
      "Production vidéo",
      "Clips musicaux",
      "Aftermovies",
      "Photographie événementielle",
      "Photographie de plateau",
      "Développement web fullstack",
      "React",
      "Laravel",
      "Astro",
      "SEO",
      "Stratégie digitale",
      "Direction artistique",
      "DaVinci Resolve",
      "Adobe Lightroom",
    ],
    address: {
      "@type": "PostalAddress",
      addressLocality: "Lausanne",
      postalCode: "1000",
      addressRegion: "Vaud",
      addressCountry: "CH",
    },
    areaServed: [
      { "@type": "City", name: "Lausanne" },
      { "@type": "State", name: "Vaud" },
      { "@type": "State", name: "Genève" },
      { "@type": "State", name: "Fribourg" },
      { "@type": "State", name: "Neuchâtel" },
      { "@type": "State", name: "Valais" },
      { "@type": "AdministrativeArea", name: "Suisse romande" },
    ],
    sameAs: [
      "https://www.instagram.com/kuasar.mknd",
      "https://github.com/kuasar-mknd",
      "https://www.youtube.com/channel/UCLPJkiQD8VAJSV3k3gSml4w",
    ],
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Quels services propose Samuel Dulex ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Samuel Dulex propose quatre services principaux : la production vidéo (clips musicaux, aftermovies, vidéos corporate), la photographie (portraits, événementiel, lifestyle), le développement web fullstack (React, Laravel, Astro, SaaS) et la stratégie digitale (SEO, Social Ads, email marketing).",
      },
    },
    {
      "@type": "Question",
      name: "Où est basé Samuel Dulex ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Samuel Dulex est basé à Lausanne, dans le canton de Vaud en Suisse romande. Il intervient dans toute la Suisse romande.",
      },
    },
    {
      "@type": "Question",
      name: "Dans quelles régions Samuel Dulex intervient-il ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Samuel Dulex intervient dans toute la Suisse romande : Lausanne, Vaud, Genève, Fribourg, Neuchâtel, Valais, Montreux, Nyon et Yverdon-les-Bains. Il se déplace également pour des projets dans toute la Suisse et à l'international.",
      },
    },
    {
      "@type": "Question",
      name: "Quelles sont les compétences techniques de Samuel Dulex ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "En développement web : React, Vue.js, Laravel, Astro, TypeScript, Tailwind CSS. En création visuelle : DaVinci Resolve, Adobe Lightroom, Figma, photographie et direction artistique. En stratégie digitale : SEO, Google Ads, Meta Ads, email marketing et CRM.",
      },
    },
  ],
};
---

<Base postData={{ data: { title, description } }} jsonLd={jsonLd}>
  <script type="application/ld+json" is:inline set:html={safeJson(faqJsonLd)} />
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <!-- Animated background elements -->
    <div class="absolute inset-0 -z-10 motion-reduce:hidden">
      <div
        class="absolute top-20 right-1/4 w-64 h-64 bg-pacamara-secondary/20 rounded-full blur-3xl floating"
      >
      </div>
      <div
        class="absolute bottom-20 left-1/4 w-96 h-96 bg-pacamara-accent/20 rounded-full blur-3xl floating-slow floating-delayed"
      >
      </div>
    </div>

    <div class="container mx-auto px-7">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24">
        <!-- Image / Visual -->
        <ScrollReveal
          direction="left"
          class="w-full lg:w-1/2 order-2 lg:order-1"
        >
          <div
            class="relative aspect-4/5 w-full max-w-md mx-auto md:max-w-none rounded-2xl overflow-hidden shadow-2xl group z-10"
          >
            <div
              class="absolute inset-0 rounded-2xl overflow-hidden image-zoom"
            >
              {
                /* ⚡ Bolt: Replaced <Picture> with <img> to reduce DOM bloat and improve parsing speed */
              }
              <img
                src={w350.src}
                srcset={`${w350.src} 350w, ${w700.src} 700w`}
                sizes="(max-width: 768px) 100vw, 350px"
                alt="Samuel Dulex"
                width={w350.attributes.width}
                height={w350.attributes.height}
                class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                loading="eager"
                decoding="sync"
                fetchpriority="high"
              />
            </div>
            <div
              class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-500"
            >
            </div>

            <!-- Floating Badge -->
            <div
              class="absolute bottom-8 left-8 bg-white/10 backdrop-blur-md border border-white/20 px-6 py-3 rounded-full text-white font-pacamara-space text-sm flex items-center gap-2"
            >
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"
              ></span>
              <span role="img" aria-label="Localisation">📍</span> Basé en Suisse
            </div>
          </div>

          <!-- Decorative elements -->
          <div
            class="absolute -bottom-10 -right-10 w-40 h-40 bg-pacamara-accent/20 rounded-full blur-3xl -z-10"
          >
          </div>
          <div
            class="absolute -top-10 -left-10 w-40 h-40 bg-pacamara-secondary/20 rounded-full blur-3xl -z-10"
          >
          </div>
        </ScrollReveal>

        <!-- Content -->
        <div class="w-full lg:w-1/2 order-1 lg:order-2 lg:pl-12">
          <ScrollReveal>
            <div
              class="inline-block px-4 py-2 rounded-full bg-pacamara-secondary/10 text-pacamara-secondary dark:text-pacamara-accent font-bold text-sm mb-6"
            >
              <span role="img" aria-label="Salut">👋</span> Enchanté, moi c'est Samuel
            </div>
          </ScrollReveal>

          <ScrollReveal delay={0.1}>
            <h1
              class="font-pacamara-space font-bold text-5xl md:text-6xl mb-8 text-pacamara-dark dark:text-white leading-tight"
            >
              Créateur Visuel & <br />
              <span class="text-shimmer">Stratège Digital.</span>
            </h1>
          </ScrollReveal>

          <ScrollReveal delay={0.2}>
            <div
              class="prose prose-lg text-pacamara-primary/80 dark:text-white/80 font-outfit font-light mb-10"
            >
              <p>
                Je ne me contente pas de capturer des images, je construis des
                expériences.
              </p>
              <p>
                Mon parcours est hybride : à la croisée de l'art visuel, du code
                et du marketing. D'un côté, je réalise des contenus qui marquent
                les esprits. De l'autre, je conçois des écosystèmes digitaux
                performants pour les diffuser.
              </p>
              <p>
                <strong>Mon objectif ?</strong> Vous offrir une vision 360° : du concept
                créatif à la conversion client.
              </p>
            </div>
          </ScrollReveal>

          <!-- Tech Stack / Skills -->
          <ScrollReveal delay={0.3}>
            <ul class="flex flex-wrap gap-3 mb-10 list-none p-0">
              {
                skills.map((skill, index) => (
                  <li
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-pacamara-primary/5 dark:bg-white/5 border border-pacamara-primary/10 dark:border-white/10 text-sm font-medium text-pacamara-primary dark:text-white/80 hover:bg-pacamara-primary/10 dark:hover:bg-white/10 transition-all duration-300 hover:scale-105 hover:shadow-md"
                    style={`animation-delay: ${index * 0.05}s`}
                  >
                    <Icon
                      name={skill.icon}
                      class="w-5 h-5 icon-animate"
                      aria-hidden="true"
                    />
                    {skill.name}
                  </li>
                ))
              }
            </ul>
          </ScrollReveal>

          <ScrollReveal delay={0.4}>
            <div class="flex flex-wrap gap-4">
              <a
                href="#contact-form"
                class="group inline-flex items-center gap-2 px-6 py-3 bg-pacamara-accent text-white rounded-full font-bold shadow-lg hover:shadow-glow hover-lift transition-all duration-300 active:scale-95 active:duration-75 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2"
                data-haptic="50"
              >
                <Icon
                  name="mdi:email-outline"
                  class="w-5 h-5 transition-transform duration-300 group-hover:scale-110 group-focus-visible:scale-110"
                  aria-hidden="true"
                />
                Me contacter
              </a>
              <a
                href="/project/"
                class="group inline-flex items-center gap-2 px-8 py-4 border border-pacamara-primary/20 dark:border-white/20 text-pacamara-primary dark:text-white rounded-full font-bold text-lg hover:bg-pacamara-primary/5 dark:hover:bg-white/10 transition-all duration-300 active:scale-95 active:duration-75 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pacamara-accent focus-visible:ring-offset-2"
                data-haptic="50"
              >
                Voir mon portfolio
                <Icon
                  name="mdi:arrow-right"
                  class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1 group-focus-visible:translate-x-1"
                  aria-hidden="true"
                />
              </a>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  {
    /* ⚡ Bolt: Performance Optimization - content-visibility skips rendering when off-screen */
  }
  <section
    class="py-24 relative overflow-hidden [content-visibility:auto] [contain-intrinsic-size:auto_800px]"
  >
    <!-- Subtle background gradient -->
    <div
      class="absolute inset-0 bg-linear-to-b from-transparent via-pacamara-secondary/5 to-transparent -z-10 pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-7 relative z-10">
      <ScrollReveal class="text-center max-w-3xl mx-auto mb-20">
        <h2
          class="text-3xl md:text-5xl font-pacamara-space font-bold mb-6 text-pacamara-dark dark:text-white"
        >
          Une approche <span class="text-shimmer">360°</span>
        </h2>
        <p
          class="text-lg text-pacamara-primary/70 dark:text-white/70 font-outfit"
        >
          Pourquoi multiplier les prestataires quand on peut avoir une vision
          unifiée ? Mon parcours technique et créatif me permet d'aborder chaque
          projet dans sa globalité. En alliant l'œil du photographe/vidéaste, la
          logique du développeur et le pragmatisme du stratège digital, je
          combine ces différentes expertises pour créer une cohérence parfaite
          entre votre image de marque, votre présence en ligne et votre
          stratégie de croissance.
        </p>
      </ScrollReveal>

      <ul class="grid grid-cols-1 md:grid-cols-2 gap-8 list-none p-0">
        {
          services.map((service, index) => (
            <li class="h-full">
              <ScrollReveal delay={0.15 * index} class="h-full">
                <TiltCard class="h-full bg-white dark:bg-pacamara-dark/80 border border-pacamara-secondary/10 dark:border-white/5 rounded-3xl shadow-lg card-glow group">
                  <div
                    class={`absolute inset-0 bg-linear-to-br ${service.gradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-3xl`}
                  />
                  <div class="relative z-10 p-8 md:p-10">
                    <div
                      class={`w-16 h-16 rounded-2xl flex items-center justify-center mb-8 ${service.color} bg-current/10 group-hover:scale-110 transition-transform duration-300`}
                    >
                      <Icon
                        name={service.icon}
                        class="w-8 h-8 icon-animate"
                        aria-hidden="true"
                      />
                    </div>
                    <h3 class="text-2xl font-bold font-pacamara-space mb-4 text-pacamara-dark dark:text-white">
                      {service.title}
                    </h3>
                    <p class="text-pacamara-primary/70 dark:text-white/70 font-outfit leading-relaxed text-lg">
                      {service.description}
                    </p>
                  </div>
                </TiltCard>
              </ScrollReveal>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <CTASection />
</Base>
